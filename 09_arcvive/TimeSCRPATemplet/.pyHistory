# Test the legend visibility function import arcpy try:     aprx = arcpy.mp.ArcGISProject(config.APR_PATH)     layout = aprx.listLayouts("Crime Report Legend")[0]     map_obj = layout.listMapFrames()[0].map          print("=== TESTING LEGEND VISIBILITY ===")          # Find the legend element     legend = None     for elm in layout.listElements("LEGEND_ELEMENT"):         print(f"Checking element: '{elm.name}' -> lower: '{elm.name.strip().lower()}'")         if elm.name.strip().lower() == "mainlegend":             legend = elm             print(f"✅ Found matching legend: {elm.name}")             break          if legend:         print("✅ Legend element found successfully")                  # Test if it has the setVisible method         if hasattr(legend, "setVisible"):             print("✅ Legend has setVisible method")                          # Test setting visibility for a layer             mv_theft_layers = [lyr for lyr in map_obj.listLayers() if "MV Theft" in lyr.name]             if mv_theft_layers:                 test_layer = mv_theft_layers[0]                 print(f"Testing with layer: {test_layer.name}")                                  try:                     legend.setVisible(test_layer, True)                     print("✅ setVisible worked!")                 except Exception as e:                     print(f"❌ setVisible failed: {e}")                      else:             print("❌ Legend does not have setVisible method")     else:         print("❌ Legend element not found")          # Clean up     del aprx      except Exception as e:     print(f"❌ Error testing legend: {e}")

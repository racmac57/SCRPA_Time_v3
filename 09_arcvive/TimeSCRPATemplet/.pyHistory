def final_legend_position_fix():     """Fix legend position to ensure it's within the export boundaries."""          try:         print("🔧 FINAL LEGEND POSITION FIX")         print("=" * 35)                  aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Use Burglary Auto layout         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  print(f"🎯 Fixing legend position: '{test_layout.name}'")                  # Check page layout dimensions         print(f"\n📐 PAGE LAYOUT ANALYSIS:")         page_width = getattr(test_layout, 'pageWidth', 'unknown')         page_height = getattr(test_layout, 'pageHeight', 'unknown')         print(f"  Page size: {page_width} x {page_height}")                  # Find map frame dimensions         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         if map_frames:             map_frame = map_frames[0]             mf_x = getattr(map_frame, 'elementPositionX', 'unknown')             mf_y = getattr(map_frame, 'elementPositionY', 'unknown')             mf_width = getattr(map_frame, 'elementWidth', 'unknown')             mf_height = getattr(map_frame, 'elementHeight', 'unknown')             print(f"  Map frame: X={mf_x}, Y={mf_y}, W={mf_width}, H={mf_height}")                  # Current legend position (from diagnostic: X:8.0, Y:8.25)         legend_elements = test_layout.listElements("LEGEND_ELEMENT")         if legend_elements:             legend = legend_elements[0]             current_x = getattr(legend, 'elementPositionX', 0)             current_y = getattr(legend, 'elementPositionY', 0)             current_w = getattr(legend, 'elementWidth', 0)             current_h = getattr(legend, 'elementHeight', 0)                          print(f"  Current legend: X={current_x}, Y={current_y}, W={current_w}, H={current_h}")                          # Check if legend is outside page boundaries             if isinstance(page_width, (int, float)) and isinstance(page_height, (int, float)):                 if current_x + current_w > page_width:                     print(f"  ⚠️ Legend extends beyond page width!")                 if current_y + current_h > page_height:                     print(f"  ⚠️ Legend extends beyond page height!")                 if current_x < 0 or current_y < 0:                     print(f"  ⚠️ Legend is positioned outside page area!")                  # TEST DIFFERENT LEGEND POSITIONS         print(f"\n🎯 TESTING LEGEND POSITIONS:")         test_output = r"C:\temp"                  # Position 1: Top-right corner (safe area)         print(f"  Position 1: Top-right corner")         if legend_elements:             legend = legend_elements[0]             legend.elementPositionX = 6.0   # 6 inches from left             legend.elementPositionY = 7.0   # 7 inches from bottom             legend.elementWidth = 2.5       # Reasonable width             legend.elementHeight = 3.5      # Reasonable height             legend.visible = True                          # Ensure all items are visible             if hasattr(legend, 'items'):                 for item in legend.items:                     if hasattr(item, 'visible'):                         item.visible = True                  pos1_path = os.path.join(test_output, "legend_position1_top_right.png")         test_layout.exportToPNG(pos1_path)         print(f"    ✅ Exported: legend_position1_top_right.png")                  # Position 2: Right side middle         print(f"  Position 2: Right side middle")         if legend_elements:             legend = legend_elements[0]             legend.elementPositionX = 7.5   # Further right             legend.elementPositionY = 4.0   # Middle height             legend.elementWidth = 2.0       # Narrower             legend.elementHeight = 4.0      # Taller                  pos2_path = os.path.join(test_output, "legend_position2_right_middle.png")         test_layout.exportToPNG(pos2_path)         print(f"    ✅ Exported: legend_position2_right_middle.png")                  # Position 3: Inside map frame (overlay)         print(f"  Position 3: Inside map frame (overlay)")         if legend_elements:             legend = legend_elements[0]             legend.elementPositionX = 0.5   # Left side             legend.elementPositionY = 6.0   # Top area             legend.elementWidth = 2.0                    legend.elementHeight = 3.0                  pos3_path = os.path.join(test_output, "legend_position3_overlay.png")         test_layout.exportToPNG(pos3_path)         print(f"    ✅ Exported: legend_position3_overlay.png")                  # Position 4: Bottom right         print(f"  Position 4: Bottom right")         if legend_elements:             legend = legend_elements[0]             legend.elementPositionX = 6.5                legend.elementPositionY = 0.5   # Bottom             legend.elementWidth = 2.5                    legend.elementHeight = 3.0                  pos4_path = os.path.join(test_output, "legend_position4_bottom_right.png")         test_layout.exportToPNG(pos4_path)         print(f"    ✅ Exported: legend_position4_bottom_right.png")                  # FINAL ANALYSIS         print(f"\n📊 POSITION TEST RESULTS:")         position_tests = [             ("Top-right corner", pos1_path),             ("Right side middle", pos2_path),             ("Inside map (overlay)", pos3_path),             ("Bottom right", pos4_path)         ]                  for desc, path in position_tests:             if os.path.exists(path):                 size = os.path.getsize(path)                 print(f"  {desc}: {size:,} bytes")             else:                 print(f"  {desc}: FILE NOT CREATED")                  print(f"\n🎉 CHECK YOUR EXPORTS:")         print(f"  📁 Location: {test_output}")         print(f"  🔍 Look for files: legend_position1 through legend
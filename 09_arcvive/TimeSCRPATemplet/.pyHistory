# Let's inspect the config.py file directly import sys import os  config_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_Hackensack_Data_Repository\GIS_Tools\Scripts\ScriptsTimeSCRPATemplet\crime_report_tool\config.py"  print("Checking config.py file...") print(f"File exists: {os.path.exists(config_path)}")  if os.path.exists(config_path):     # Read the first few lines to see the structure     with open(config_path, 'r', encoding='utf-8') as f:         lines = f.readlines()[:20]  # First 20 lines          print("First 20 lines of config.py:")     for i, line in enumerate(lines, 1):         print(f"{i:2d}: {line.rstrip()}")          # Check if CRIME_TYPES is defined     with open(config_path, 'r', encoding='utf-8') as f:         content = f.read()          if 'CRIME_TYPES' in content:         print("✅ CRIME_TYPES found in config.py")     else:         print("❌ CRIME_TYPES not found in config.py")          # Try to execute the config file manually     try:         print("\nTrying to execute config.py manually...")         with open(config_path, 'r', encoding='utf-8') as f:             config_content = f.read()                  # Create a new namespace to execute config         config_namespace = {}         exec(config_content, config_namespace)                  # Check what's available         print("Variables defined in config:")         for key, value in config_namespace.items():             if not key.startswith('__'):                 print(f"  {key}: {type(value)}")                 if key == 'CRIME_TYPES':                     print(f"    Value: {value}")              except Exception as e:         print(f"❌ Error executing config.py: {e}")
import sys import os from pathlib import Path  # Manually load the config values crime_tool_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_Hackensack_Data_Repository\GIS_Tools\Scripts\ScriptsTimeSCRPATemplet\crime_report_tool"  # Execute config.py to get the values config_namespace = {} with open(os.path.join(crime_tool_path, 'config.py'), 'r', encoding='utf-8') as f:     exec(f.read(), config_namespace)  # Extract the values we need CRIME_TYPES = config_namespace['CRIME_TYPES'] SUFFIXES = config_namespace['SUFFIXES']  print(f"✅ Loaded CRIME_TYPES: {CRIME_TYPES}") print(f"✅ Loaded SUFFIXES: {SUFFIXES}")  # Now let's test the core folder creation functionality directly def get_report_name_from_date(target_date_str):     excel_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\InBox\GIS_Tools\7Day_28Day_Cycle_20250414.xlsx"     try:         import pandas as pd         df = pd.read_excel(excel_path, sheet_name="7Day_28Day_250414")         df['Report_Due_Date'] = pd.to_datetime(df['Report_Due_Date'])         target_date = pd.to_datetime(target_date_str.replace('_', '-'))         match = df[df['Report_Due_Date'].dt.date == target_date.date()]                  if not match.empty:             report_name = match.iloc[0]['Report_Name']             print(f"✅ Found Report_Name: {report_name} for date: {target_date_str}")             return report_name         else:             return f"UNKNOWN_{target_date_str}"     except Exception as e:         print(f"❌ Error: {e}")         return f"ERROR_{target_date_str}"  def get_crime_type_subfolder(crime_type):     """Convert crime type to subfolder name."""     crime_type_mapping = {         'mv theft': 'Motor_Vehicle_Theft',         'motor vehicle theft': 'Motor_Vehicle_Theft',         'burglary - auto': 'Burglary_Auto',         'burglary auto': 'Burglary_Auto',         'burglary - comm & res': 'Burglary_Commercial_Residential',         'robbery': 'Robbery',         'sexual offenses': 'Sexual_Offenses',     }          crime_lower = crime_type.lower().strip()     for key, value in crime_type_mapping.items():         if key in crime_lower:             return value          clean_name = crime_type.replace(' - ', '_').replace(' & ', '_').replace(' ', '_')     return clean_name  # Test the complete folder creation process def test_dynamic_folder_creation():     print("\n🚀 Testing dynamic folder creation...")          date_str = "2025_05_27"     base_folder = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports"          # Get report name     report_name = get_report_name_from_date(date_str)          # Create main folder     main_folder_name = f"{report_name}_{date_str}"     main_folder_path = os.path.join(base_folder, main_folder_name)          Path(main_folder_path).mkdir(parents=True, exist_ok=True)     print(f"✅ Created main folder: {main_folder_path}")          # Create subfolders for each crime type     for crime_type in CRIME_TYPES:         subfolder_name = get_crime_type_subfolder(crime_type)         subfolder_path = os.path.join(main_folder_path, subfolder_name)         Path(subfolder_path).mkdir(parents=True, exist_ok=True)         print(f"✅ Created subfolder: {crime_type} → {subfolder_name}")          print(f"\n🎉 SUCCESS! Dynamic folder structure created at: {main_folder_path}")     return main_folder_path  # Run the test result_path = test_dynamic_folder_creation()

import arcpy  class Toolbox(object):     def __init__(self):         self.label = "Run Crime Report Automation"         self.alias = "RunCrimeTool"         self.tools = [RunCrimeTool]  # Reference your tool class here  class RunCrimeTool(object):     def __init__(self):         self.label = "Run Crime Report"         self.description = "Generates crime report chart based on CSV and crime type"      def getParameterInfo(self):         params = []          # Crime Type         param0 = arcpy.Parameter(             displayName="Crime Type",             name="crime_type",             datatype="GPString",             parameterType="Required",             direction="Input"         )         param0.filter.type = "ValueList"         param0.filter.list = [             "MV Theft",             "Burglary - Auto",             "Burglary - Comm & Res",             "Robbery",             "Sexual Offenses"         ]         params.append(param0)          # Input CSV         param1 = arcpy.Parameter(             displayName="Input CSV",             name="input_csv",             datatype="DEFile",             parameterType="Required",             direction="Input"         )         params.append(param1)          # Chart Path         param2 = arcpy.Parameter(             displayName="Chart Output Path",             name="chart_path",             datatype="DEFile",             parameterType="Required",             direction="Output"         )         params.append(param2)          # Report Toggle         param3 = arcpy.Parameter(             displayName="Generate Report?",             name="report",             datatype="GPBoolean",             parameterType="Required",             direction="Input"         )         params.append(param3)          return params      def execute(self, parameters, messages):         crime_type = parameters[0].valueAsText         input_csv = parameters[1].valueAsText         chart_path = parameters[2].valueAsText         report = parameters[3].value          arcpy.AddMessage(f"?? Running crime report for {crime_type}")         arcpy.AddMessage(f"?? CSV: {input_csv}")         arcpy.AddMessage(f"???  Chart: {chart_path}")         arcpy.AddMessage(f"?? Report: {report}")         # call your real script here, e.g. main.run(...)

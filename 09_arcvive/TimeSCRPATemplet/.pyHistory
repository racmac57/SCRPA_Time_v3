# Save the hybrid script to your folder import os  os.chdir(r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\TimeSCRPATemplet")  # The hybrid script content hybrid_script = '''import arcpy import os import sys import argparse import pandas as pd from datetime import datetime from pathlib import Path  def get_report_name_from_date(target_date_str):     """Load Excel file and return the corresponding Report_Name for the given date."""     excel_path = r"C:\\Users\\carucci_r\\OneDrive - City of Hackensack\\InBox\\GIS_Tools\\7Day_28Day_Cycle_20250414.xlsx"          try:         df = pd.read_excel(excel_path, sheet_name="7Day_28Day_250414")         df['Report_Due_Date'] = pd.to_datetime(df['Report_Due_Date'])         target_date = pd.to_datetime(target_date_str.replace('_', '-'))         match = df[df['Report_Due_Date'].dt.date == target_date.date()]                  if not match.empty:             report_name = match.iloc[0]['Report_Name']             arcpy.AddMessage(f"Found Report_Name: {report_name} for date: {target_date_str}")             return report_name         else:             arcpy.AddWarning(f"No matching Report_Name for date: {target_date_str}")             return f"UNKNOWN_{target_date_str}"                  except Exception as e:         arcpy.AddError(f"Error reading Excel file: {e}")         return f"ERROR_{target_date_str}"  def get_crime_type_from_layout_name(layout_name):     """Extract crime type from layout name to determine subfolder."""     crime_type_mapping = {         'burglary - auto': 'Burglary_Auto',         'burglary - comm & res': 'Burglary_Commercial_Residential',         'crime_reporting_layout': 'Motor_Vehicle_Theft',         'robbery': 'Robbery',         'sexual offenses': 'Sexual_Offenses'     }          layout_lower = layout_name.lower()     for key, value in crime_type_mapping.items():         if key in layout_lower:             return value          clean_name = layout_name.replace(' ', '_').replace('-', '_')     return clean_name  def export_layout_png(layout, main_output_path, layout_name, date_str):     """Export a single layout to the appropriate crime-type subfolder as PNG."""     try:         crime_type = get_crime_type_from_layout_name(layout_name)         crime_subfolder = os.path.join(main_output_path, crime_type)                  if not os.path.exists(crime_subfolder):             os.makedirs(crime_subfolder)             arcpy.AddMessage(f"Created crime type subfolder: {crime_subfolder}")                  safe_date = date_str.replace('_', '-')         filename = f"{layout_name}_{safe_date}.png"         full_path = os.path.join(crime_subfolder, filename)                  layout.exportToPNG(full_path, resolution=300)         arcpy.AddMessage(f"Exported PNG: {full_path}")                  return True, full_path, crime_type              except Exception as e:         arcpy.AddError(f"Error exporting {layout_name}: {e}")         return False, None, None  def main():     """Main function."""     try:         parser = argparse.ArgumentParser(description='Export ArcGIS Pro layouts with dynamic folder naming')         parser.add_argument('--mode', choices=['all', 'specific'], required=True)         parser.add_argument('--layout', type=str)         parser.add_argument('--date', type=str, required=True)         parser.add_argument('--aprx_path', type=str,                           default=r"C:\\Users\\carucci_r\\OneDrive - City of Hackensack\\_25_SCRPA\\TIME_Based\\TimeSCRPATemplet\\TimeSCRPATemplet.aprx")                  args = parser.parse_args()                  datetime.strptime(args.date, '%Y_%m_%d')                  arcpy.AddMessage(f"Starting HYBRID export process...")         arcpy.AddMessage(f"Mode: {args.mode}, Date: {args.date}")                  # Setup project         aprx = arcpy.mp.ArcGISProject(args.aprx_path)         maps = aprx.listMaps()         layouts = aprx.listLayouts()                  # Get dynamic folder name         report_name = get_report_name_from_date(args.date)         folder_name = f"{report_name}_{args.date}"                  base_output_path = r"C:\\Users\\carucci_r\\OneDrive - City of Hackensack\\_25_SCRPA\\TIME_Based\\Reports"         main_output_path = os.path.join(base_output_path, folder_name)                  if not os.path.exists(main_output_path):             os.makedirs(main_output_path)             arcpy.AddMessage(f"Created main directory: {main_output_path}")                  # Create crime-type subfolders         crime_subfolders = ['Motor_Vehicle_Theft', 'Burglary_Auto', 'Burglary_Commercial_Residential', 'Robbery', 'Sexual_Offenses']         for subfolder in crime_subfolders:             subfolder_path = os.path.join(main_output_path, subfolder)             Path(subfolder_path).mkdir(exist_ok=True)                  successful_exports = 0         failed_exports = 0                  # Export layouts         for layout in layouts:             if layout.name == "Crime Report Legend":                 continue                              success, export_path, crime_type = export_layout_png(layout, main_output_path, layout.name, args.date)             if success:                 successful_exports += 1             else:                 failed_exports += 1                  arcpy.AddMessage(f"Export complete! PNG exports: {successful_exports} successful, {failed_exports} failed")                  del aprx              except Exception as e:         arcpy.AddError(f"Error: {e}")  if __name__ == "__main__":     main() '''  # Save the script with open('Hybrid_Dynamic_Folder_Script.py', 'w', encoding='utf-8') as f:     f.write(hybrid_script)  print("✅ Hybrid script saved!")  # Now test it import sys sys.argv = ['Hybrid_Dynamic_Folder_Script.py', '--mode', 'all', '--date', '2025_05_27']  print("🚀 Testing HYBRID script...") exec(open('Hybrid_Dynamic_Folder_Script.py').read())
import arcpy  def diagnose_legend_issues():     """Diagnostic script to identify legend problems"""          aprx = arcpy.mp.ArcGISProject("CURRENT")     layout = aprx.listLayouts()[0]  # Use first layout          print("=== LEGEND DIAGNOSTIC ===")          # Check all layout elements     print("\nLayout Elements:")     for element in layout.listElements():         print(f"  - {element.__class__.__name__}: {getattr(element, 'name', 'unnamed')}")         if hasattr(element, 'visible'):             print(f"    Visible: {element.visible}")          # Focus on legend elements     print("\nLegend Elements Details:")     legend_elements = layout.listElements("LEGEND_ELEMENT")          if not legend_elements:         print("❌ NO LEGEND ELEMENTS FOUND!")         print("You may need to add a legend to your layout manually.")         return          for i, legend in enumerate(legend_elements):         print(f"\nLegend {i+1}:")         print(f"  Visible: {legend.visible}")         print(f"  Name: {getattr(legend, 'name', 'unnamed')}")                  # Check legend items         try:             items = legend.items             print(f"  Legend items count: {len(items)}")             for j, item in enumerate(items):                 print(f"    Item {j+1}: {item.name} (Visible: {item.showLabels})")         except Exception as e:             print(f"  Error accessing legend items: {e}")          # Check map frame and layers     print("\nMap Frame and Layers:")     map_frames = layout.listElements("MAPFRAME_ELEMENT")          if map_frames:         map_frame = map_frames[0]         map_obj = map_frame.map         print(f"Map: {map_obj.name}")                  print("Visible Layers:")         for layer in map_obj.listLayers():             if layer.visible:                 print(f"  ✅ {layer.name}")             else:                 print(f"  ❌ {layer.name} (hidden)")          print("\n=== END DIAGNOSTIC ===")  if __name__ == "__main__":     diagnose_legend_issues()

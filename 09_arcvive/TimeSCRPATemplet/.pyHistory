# Check your complete report output import os import glob  output_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\C05W23_2025_06_03" chart_dir = r"C:\GIS_Data\SCRPA\charts"  print("📊 COMPLETE REPORT PACKAGE") print("=" * 50)  # Check maps in report folder print(f"\n📍 MAPS (in {output_dir}):") map_files = glob.glob(os.path.join(output_dir, "*.png")) for file in sorted(map_files):     size_kb = os.path.getsize(file) // 1024     print(f"  ✅ {os.path.basename(file)} ({size_kb:,} KB)")  # Check charts in chart directory print(f"\n📈 CHARTS (in {chart_dir}):") chart_files = glob.glob(os.path.join(chart_dir, "*_Chart.png")) for file in sorted(chart_files):     size_kb = os.path.getsize(file) // 1024     print(f"  ✅ {os.path.basename(file)} ({size_kb} KB)")  # Check summary report summary_file = os.path.join(output_dir, "processing_summary.txt") if os.path.exists(summary_file):     print(f"\n📋 SUMMARY REPORT:")     print(f"  ✅ {os.path.basename(summary_file)}")  print(f"\n🎯 TOTAL FILES:") print(f"  Maps: {len(map_files)}") print(f"  Charts: {len(chart_files)}") print(f"  Summary: 1") print(f"  GRAND TOTAL: {len(map_files) + len(chart_files) + 1} files")  print(f"\n📂 Access your report at:") print(f"  {output_dir}")
# Copy all charts to your main report folder import shutil import os import glob  source_dir = r"C:\GIS_Data\SCRPA\charts" target_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\C05W23_2025_06_03"  print("📋 Copying charts to main report folder...")  # Get all chart files chart_files = glob.glob(os.path.join(source_dir, "*_Chart.png"))  copied_count = 0 for chart_file in chart_files:     try:         filename = os.path.basename(chart_file)         target_path = os.path.join(target_dir, filename)                  shutil.copy2(chart_file, target_path)         size_kb = os.path.getsize(target_path) // 1024         print(f"  ✅ Copied {filename} ({size_kb} KB)")         copied_count += 1              except Exception as e:         print(f"  ❌ Failed to copy {os.path.basename(chart_file)}: {e}")  print(f"\n🎯 Successfully copied {copied_count} charts to report folder")  # Verify everything is now in one place print(f"\n📂 COMPLETE REPORT FOLDER CONTENTS:") all_files = os.listdir(target_dir) png_files = [f for f in all_files if f.endswith('.png')] other_files = [f for f in all_files if not f.endswith('.png')]  print(f"\n📍 Maps & Charts ({len(png_files)} files):") for file in sorted(png_files):     file_path = os.path.join(target_dir, file)     size_kb = os.path.getsize(file_path) // 1024     file_type = "MAP" if "_Map.png" in file else "CHART"     print(f"  ✅ {file} ({size_kb} KB) [{file_type}]")  print(f"\n📋 Other Files:") for file in other_files:     print(f"  ✅ {file}")  print(f"\n🎉 COMPLETE REPORT PACKAGE READY!") print(f"📂 Location: {target_dir}") print(f"📊 Total: {len(png_files)} visualizations + summary")
# Debug version to test database connection and SQL queries # Run this in ArcGIS Pro Python window to diagnose the issues  import os import arcpy from datetime import date, datetime, timedelta  # Test configuration crime_type = "Sexual Offenses" APR_PATH = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\TimeSCRPATemplet\TimeSCRPATemplet.aprx"  print(f"🔍 DEBUGGING {crime_type} Database Connection") print("=" * 60)  try:     # Load ArcGIS Pro project     aprx = arcpy.mp.ArcGISProject(APR_PATH)     maps = aprx.listMaps()     map_obj = maps[0]          print(f"✅ Connected to project: {APR_PATH}")     print(f"✅ Found {len(maps)} maps")          # List all layers     print(f"\n📋 ALL LAYERS IN PROJECT:")     for i, lyr in enumerate(map_obj.listLayers()):         print(f"  {i+1}. {lyr.name}")          # Test each period for Sexual Offenses     periods = ["7-Day", "28-Day", "YTD"]          for period in periods:         layer_name = f"{crime_type} {period}"         print(f"\n🔍 TESTING: {layer_name}")                  # Find the layer         target_layer = None         for lyr in map_obj.listLayers():             if lyr.name == layer_name:                 target_layer = lyr                 break                  if target_layer:             print(f"  ✅ Found layer: {target_layer.name}")                          # Check current definition query             current_query = target_layer.definitionQuery             print(f"  📋 Current definition query: {current_query}")                          # Test feature count with current query             try:                 feature_count = int(arcpy.GetCount_management(target_layer).getOutput(0))                 print(f"  📊 Current feature count: {feature_count}")             except Exception as e:                 print(f"  ❌ Error getting feature count: {e}")                          # Test different SQL formats             test_queries = [                 # Format 1: Your project format                 f"calltype LIKE '%Sexual%' And disposition LIKE '%See Report%' And calldate >= (current_date-{7 if period == '7-Day' else 28 if period == '28-Day' else 365})",                                  # Format 2: Quoted fields                 f'"calltype" LIKE \'%Sexual%\' AND "disposition" LIKE \'%See Report%\' AND "calldate" >= (current_date-{7 if period == "7-Day" else 28 if period == "28-Day" else 365})',                                  # Format 3: Timestamp format                   f"calltype LIKE '%Sexual%' And disposition LIKE '%See Report%' And calldate >= timestamp '2025-05-27 00:00:00.000'" if period == "7-Day" else                 f"calltype LIKE '%Sexual%' And disposition LIKE '%See Report%' And calldate >= timestamp '2025-05-06 00:00:00.000'" if period == "28-Day" else                 f"calltype LIKE '%Sexual%' And disposition LIKE '%See Report%' And calldate >= timestamp '2025-01-01 00:00:00.000'"             ]                          print(f"  🧪 TESTING SQL FORMATS:")             for i, test_query in enumerate(test_queries, 1):                 try:                     # Apply test query                     target_layer.definitionQuery = test_query                     test_count = int(arcpy.GetCount_management(target_layer).getOutput(0))                     print(f"    Format {i}: {test_count} features")                     print(f"      SQL: {test_query}")                                          if test_count > 0:                         print(f"    ✅ SUCCESS! Found {test_count} features with Format {i}")                                                  # Try to get field info if features found                         try:                             fields = [field.name for field in arcpy.ListFields(target_layer)]                             print(f"    📋 Available fields: {fields[:10]}...")  # Show first 10                                                          # Try to read actual data                             possible_time_fields = ['calltime', 'calldate', 'time', 'date']                             available_time_fields = [f for f in possible_time_fields if f in fields]                                                          if available_time_fields:                                 print(f"    🕒 Time fields available: {available_time_fields}")                                                                  # Try to read a few records                                 with arcpy.da.SearchCursor(target_layer, available_time_fields[:2] if len(available_time_fields) > 1 else available_time_fields) as cursor:                                     for j, row in enumerate(cursor):                                         if j < 3:  # Show first 3 records                                             print(f"      Record {j+1}: {row}")                                         else:                                             break                             else:                                 print(f"    ⚠️ No time fields found")                                                          except Exception as e:                             print(f"    ❌ Error reading data: {e}")                                      except Exception as e:                     print(f"    ❌ Format {i} failed: {e}")                          # Restore original query             target_layer.definitionQuery = current_query                      else:             print(f"  ❌ Layer not found: {layer_name}")          print(f"\n🎯 SUMMARY:")     print("- Which SQL format returned the expected feature counts?")     print("- Are time fields available for temporal analysis?")     print("- Do the feature counts match your database logs?")      except Exception as e:     print(f"❌ Major error: {e}")     import traceback     traceback.print_exc()  print("\n" + "=" * 60) print("Run this script and tell me which SQL format works!")
# Debug script to check Sexual Offenses map layer visibility and transparency import arcpy  APR_PATH = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\TimeSCRPATemplet\TimeSCRPATemplet.aprx"  print(f"🔍 DEBUGGING Sexual Offenses Map Visibility") print("=" * 60)  # Load project aprx = arcpy.mp.ArcGISProject(APR_PATH) map_obj = aprx.listMaps()[0]  # Check Sexual Offenses layers for layer_name in ["Sexual Offenses 7-Day", "Sexual Offenses 28-Day", "Sexual Offenses YTD"]:     print(f"\n🔍 CHECKING: {layer_name}")          target_layer = None     for lyr in map_obj.listLayers():         if lyr.name == layer_name:             target_layer = lyr             break          if target_layer:         print(f"  ✅ Found layer: {target_layer.name}")         print(f"  👁️ Visible: {target_layer.visible}")         print(f"  🎨 Transparency: {target_layer.transparency}%")         print(f"  📋 Definition Query: {target_layer.definitionQuery}")                  try:             feature_count = int(arcpy.GetCount_management(target_layer).getOutput(0))             print(f"  📊 Feature Count: {feature_count}")         except Exception as e:             print(f"  ❌ Error getting count: {e}")     else:         print(f"  ❌ Layer not found: {layer_name}")  # Check layer order print(f"\n📋 SEXUAL OFFENSES LAYER ORDER:") for i, lyr in enumerate(map_obj.listLayers()):     if "Sexual Offenses" in lyr.name:         visibility = "👁️" if lyr.visible else "🚫"         print(f"  {i+1}. {visibility} {lyr.name} ({lyr.transparency}%)")  print("=" * 60)
import arcpy  # Quick check of Sexual Offenses 28-Day after your change aprx = arcpy.mp.ArcGISProject(r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\TimeSCRPATemplet\TimeSCRPATemplet.aprx") map_obj = aprx.listMaps()[0]  for lyr in map_obj.listLayers():     if lyr.name == "Sexual Offenses 28-Day":         print(f"📋 Current Query: {lyr.definitionQuery}")         try:             count = int(arcpy.GetCount_management(lyr).getOutput(0))             print(f"📊 Feature Count: {count}")         except Exception as e:             print(f"❌ Error: {e}")         break

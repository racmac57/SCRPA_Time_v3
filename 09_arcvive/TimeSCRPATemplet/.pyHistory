def simple_export_test():     """Simple export test with basic file path."""          try:         print("🔧 SIMPLE EXPORT TEST")         print("=" * 30)                  aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Get Burglary Auto layout         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  print(f"🎯 Testing: '{test_layout.name}'")                  # Use a simpler output path - desktop         import os         desktop_path = os.path.join(os.path.expanduser("~"), "Desktop")         test_filename = "TEST_EXPORT.png"         test_path = os.path.join(desktop_path, test_filename)                  print(f"📁 Output: {test_path}")                  # Apply all our fixes         print(f"\n🔗 Applying fixes...")                  # Layer setup         for layer in current_map.listLayers():             if "Burglary - Auto" in layer.name:                 layer.visible = True             elif any(crime in layer.name for crime in ["MV Theft", "Robbery", "Sexual"]):                 layer.visible = False             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                 layer.visible = True                  # Rotation fix         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         if map_frames:             camera = map_frames[0].camera             camera.heading = 0             camera.scale = 25000             camera.X = -8242906             camera.Y = 4995946             print(f"  ✅ Rotation fixed")                  # Legend fix         legend_elements = test_layout.listElements("LEGEND_ELEMENT")         if legend_elements:             legend = legend_elements[0]             legend.visible = True                          if hasattr(legend, 'items'):                 for item in legend.items:                     if hasattr(item, 'visible'):                         item.visible = True             print(f"  ✅ Legend fixed")                  # Try the simplest possible export         print(f"\n📤 Exporting...")         try:             test_layout.exportToPNG(test_path)                          if os.path.exists(test_path):                 file_size = os.path.getsize(test_path)                 print(f"  ✅ SUCCESS! Export created on desktop")                 print(f"  📊 File size: {file_size:,} bytes")                 print(f"  📁 Location: {test_path}")                                  print(f"\n🎉 CHECK YOUR DESKTOP FOR: {test_filename}")                 print(f"This export should have:")                 print(f"  ✅ Correct orientation (north up)")                 print(f"  ✅ Visible legend")                 print(f"  ✅ Proper zoom on Hackensack")                                  return True             else:                 print(f"  ❌ File not created")                 return False                  except Exception as e:             print(f"  ❌ Export error: {e}")             return False          except Exception as e:         print(f"❌ Critical error: {e}")         return False  # Test with simple path if simple_export_test():     print(f"\n🚀 SUCCESS! Now let's run the full production version...")          def run_production_with_working_method():         """Run production export using the working method."""         try:             print(f"\n🔥 RUNNING PRODUCTION EXPORT")             print("=" * 35)                          aprx = arcpy.mp.ArcGISProject("CURRENT")             current_map = aprx.listMaps()[0]             layouts = aprx.listLayouts()                          # Use the same output folder structure as before             test_date = "2025_05_30"             base_output = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports"             main_folder = f"WORKING_EXPORTS_{test_date}"             main_output = os.path.join(base_output, main_folder)                          # Ensure output directory exists             os.makedirs(main_output, exist_ok=True)             print(f"📁 Main output: {main_folder}")                          # Crime layout configurations             crime_configs = {                 'Crime_Reporting_Layout': {                     'pattern': 'MV Theft',                     'subfolder': 'Motor_Vehicle_Theft',                     'filename': 'MV_Theft_Layout'                 },                 'Burglary - Auto': {                     'pattern': 'Burglary - Auto',                     'subfolder': 'Burglary_Auto',                      'filename': 'Burglary_Auto_Layout'                 },                 'Burglary - Comm & Res': {                     'pattern': 'Burglary - Comm & Res',                     'subfolder': 'Burglary_Commercial_Residential',                     'filename': 'Burglary_Commercial_Residential_Layout'                 },                 'Robbery': {                     'pattern': 'Robbery',                     'subfolder': 'Robbery',                     'filename': 'Robbery_Layout'                 },                 'Sexual Offenses': {                     'pattern': 'Sexual Offenses',                     'subfolder': 'Sexual_Offenses',                     'filename': 'Sexual_Offenses_Layout'                 }             }                          # Create all subfolders             for config in crime_configs.values():                 subfolder_path = os.path.join(main_output, config['subfolder'])                 os.makedirs(subfolder_path, exist_ok=True)                          successful = 0             failed = 0                          # Process each layout             for layout in layouts:                 if layout.name == "Crime Report Legend":                     continue                                      if layout.name in crime_configs:                     config = crime_configs[layout.name]                     print(f"\n[{successful + failed + 1}] Processing: '{layout.name}'")                                          try:                         # Configure layers for this crime type                         for layer in current_map.listLayers():                             if config['pattern'] in layer.name:                                 layer.visible = True                             elif any(crime in layer.name for crime in ["MV Theft", "Burglary", "Robbery", "Sexual"]):                                 layer.visible = False                             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                                 layer.visible = True                                                  # Apply rotation and zoom fixes                         map_frames = layout.listElements("MAPFRAME_ELEMENT")                         if map_frames:                             camera = map_frames[0].camera                             camera.heading = 0       # North up                             camera.scale = 25000     # Good city-level scale                             camera.X = -8242906      # Center on Hackensack                             camera.Y = 4995946                                                  # Apply legend fixes (if layout has legend)                         legend_elements = layout.listElements("LEGEND_ELEMENT")                         if legend_elements:                             legend = legend_elements[0]                             legend.visible = True                                                          # Force all legend items visible                             if hasattr(legend, 'items'):                                 for item in legend.items:                                     if hasattr(item, 'visible'):                                         item.visible = True                             print(f"  ✅ Legend configured")                         else:                             print(f"  ⚠️ No legend in this layout")                                                  # Generate export path                         safe_date = test_date.replace('_', '-')                         filename = f"{config['filename']}_{safe_date}.png"                         export_path = os.path.join(main_output, config['subfolder'], filename)                                                  # Export using the working method                         layout.exportToPNG(export_path)                                                  # Verify export                         if os.path.exists(export_path):                             file_size = os.path.getsize(export_path)                             print(f"  ✅ Success: {filename} ({file_size:,} bytes)")                             successful += 1                         else:                             print(f"  ❌ Failed: File not created")                             failed += 1                                                  except Exception as e:                         print(f"  ❌ Error: {e}")                         failed += 1                          # Final summary             total = successful + failed             print(f"\n📊 PRODUCTION SUMMARY:")             print(f"✅ Successful exports: {successful}")             print(f"❌ Failed exports: {failed}")             print(f"🎯 Success rate: {(successful/total)*100:.1f}%")             print(f"📁 Output folder: {main_output}")                          if successful > 0:                 print(f"\n🎉 PRODUCTION COMPLETE!")                 print(f"Your exports now have:")                 print(f"  ✅ Correct orientation (north up)")                 print(f"  ✅ Visible legends (where available)")                 print(f"  ✅ Proper filenames")                 print(f"  ✅ Good zoom level on Hackensack")                 print(f"  ✅ Organized in crime-specific subfolders")                      except Exception as e:             print(f"❌ Production error: {e}")          # Run the production version     run_production_with_working_method()  else:     print(f"\n❌ Simple test failed - need to troubleshoot export issue")
def troubleshoot_export():     """Troubleshoot the basic export functionality."""          try:         print("🔍 TROUBLESHOOTING EXPORT")         print("=" * 30)                  aprx = arcpy.mp.ArcGISProject("CURRENT")         layouts = aprx.listLayouts()                  # Get any layout for testing         test_layout = layouts[0] if layouts else None         if not test_layout:             print("❌ No layouts found")             return                  print(f"🎯 Testing with: '{test_layout.name}'")                  # Test 1: Check if layout has exportToPNG method         print(f"\n🔍 Method Check:")         if hasattr(test_layout, 'exportToPNG'):             print(f"  ✅ Layout has exportToPNG method")         else:             print(f"  ❌ Layout missing exportToPNG method")             return                  # Test 2: Try export to different locations         test_locations = [             r"C:\temp\test.png",             r"C:\Users\carucci_r\test.png",              r"C:\test.png"         ]                  for i, test_path in enumerate(test_locations, 1):             print(f"\n📤 Test {i}: {test_path}")                          try:                 # Ensure directory exists                 import os                 test_dir = os.path.dirname(test_path)                 if test_dir and not os.path.exists(test_dir):                     os.makedirs(test_dir, exist_ok=True)                     print(f"  📁 Created directory: {test_dir}")                                  # Try the most basic export                 test_layout.exportToPNG(test_path)                                  # Check if file was created                 if os.path.exists(test_path):                     file_size = os.path.getsize(test_path)                     print(f"  ✅ SUCCESS! File created: {file_size:,} bytes")                                          # Clean up test file                     try:                         os.remove(test_path)                         print(f"  🧹 Test file cleaned up")                     except:                         pass                                          return test_path  # Return successful path                 else:                     print(f"  ❌ File not created (no error thrown)")                                  except Exception as e:                 print(f"  ❌ Export error: {e}")                 print(f"  🔍 Error type: {type(e).__name__}")                  # Test 3: Try different export methods         print(f"\n📤 Testing Alternative Export Methods:")                  # Check what export methods are available         export_methods = [method for method in dir(test_layout) if 'export' in method.lower()]         print(f"  Available export methods: {export_methods}")                  # Try exportToPDF as alternative         if hasattr(test_layout, 'exportToPDF'):             print(f"\n📤 Testing PDF export:")             try:                 pdf_path = r"C:\temp\test.pdf"                 os.makedirs(os.path.dirname(pdf_path), exist_ok=True)                                  test_layout.exportToPDF(pdf_path)                                  if os.path.exists(pdf_path):                     file_size = os.path.getsize(pdf_path)                     print(f"  ✅ PDF export works! {file_size:,} bytes")                                          # Clean up                     try:                         os.remove(pdf_path)                     except:                         pass                                      else:                     print(f"  ❌ PDF export failed")                                  except Exception as e:                 print(f"  ❌ PDF export error: {e}")                  # Test 4: Check ArcGIS Pro version and environment         print(f"\n🔍 Environment Check:")         try:             install_info = arcpy.GetInstallInfo()             print(f"  ArcGIS Version: {install_info.get('Version', 'Unknown')}")             print(f"  Product Name: {install_info.get('ProductName', 'Unknown')}")             print(f"  License Level: {install_info.get('LicenseLevel', 'Unknown')}")         except Exception as e:             print(f"  ⚠️ Could not get install info: {e}")                  # Test 5: Check if we need to use different syntax         print(f"\n🔍 Testing Different Export Syntax:")         try:             # Method 1: With explicit parameters             test_path = r"C:\temp\syntax_test1.png"             os.makedirs(os.path.dirname(test_path), exist_ok=True)                          test_layout.exportToPNG(test_path, 300)  # Resolution as second parameter                          if os.path.exists(test_path):                 print(f"  ✅ Syntax 1 works (path, resolution)")                 os.remove(test_path)                 return "syntax1"                      except Exception as e:             print(f"  ❌ Syntax 1 error: {e}")                  try:             # Method 2: Named parameters             test_path = r"C:\temp\syntax_test2.png"             test_layout.exportToPNG(out_png=test_path, resolution=300)                          if os.path.exists(test_path):                 print(f"  ✅ Syntax 2 works (named parameters)")                 os.remove(test_path)                 return "syntax2"                      except Exception as e:             print(f"  ❌ Syntax 2 error: {e}")                  print(f"\n❌ All export tests failed")         return None              except Exception as e:         print(f"❌ Critical troubleshooting error: {e}")         return None  # Run the troubleshooting result = troubleshoot_export()  if result:     print(f"\n🎉 Found working export method!")     print(f"Now we can apply this to your layouts with all the fixes.") else:     print(f"\n❌ Export functionality appears to be broken.")     print(f"This might be an ArcGIS Pro environment issue.")     print(f"Try:")     print(f"  1. Restart ArcGIS Pro")     print(f"  2. Check if you have write permissions")     print(f"  3. Try running ArcGIS Pro as administrator")
def final_production_export():     """Final production export with all fixes using the working method."""          try:         print("🚀 FINAL PRODUCTION EXPORT WITH ALL FIXES")         print("=" * 50)                  aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Setup output directory         test_date = "2025_05_30"         base_output = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports"         main_folder = f"FINAL_FIXED_EXPORTS_{test_date}"         main_output = os.path.join(base_output, main_folder)                  # Create main directory         os.makedirs(main_output, exist_ok=True)         print(f"📁 Output folder: {main_folder}")                  # Crime layout configurations         crime_configs = {             'Crime_Reporting_Layout': {                 'pattern': 'MV Theft',                 'subfolder': 'Motor_Vehicle_Theft',                 'filename': 'MV_Theft_Layout',                 'has_legend': False             },             'Burglary - Auto': {                 'pattern': 'Burglary - Auto',                 'subfolder': 'Burglary_Auto',                  'filename': 'Burglary_Auto_Layout',                 'has_legend': True             },             'Burglary - Comm & Res': {                 'pattern': 'Burglary - Comm & Res',                 'subfolder': 'Burglary_Commercial_Residential',                 'filename': 'Burglary_Commercial_Residential_Layout',                 'has_legend': True             },             'Robbery': {                 'pattern': 'Robbery',                 'subfolder': 'Robbery',                 'filename': 'Robbery_Layout',                 'has_legend': True             },             'Sexual Offenses': {                 'pattern': 'Sexual Offenses',                 'subfolder': 'Sexual_Offenses',                 'filename': 'Sexual_Offenses_Layout',                 'has_legend': True             }         }                  # Create all subfolders         for config in crime_configs.values():             subfolder_path = os.path.join(main_output, config['subfolder'])             os.makedirs(subfolder_path, exist_ok=True)                  print(f"📁 Created {len(crime_configs)} crime-specific subfolders")                  successful = 0         failed = 0                  # Process each layout         for layout in layouts:             if layout.name == "Crime Report Legend":                 print(f"⏭️ Skipping: {layout.name}")                 continue                              if layout.name in crime_configs:                 config = crime_configs[layout.name]                 print(f"\n[{successful + failed + 1}] Processing: '{layout.name}'")                                  try:                     # STEP 1: Configure layers for this crime type                     print(f"  🔗 Configuring layers for: {config['pattern']}")                     enabled_layers = []                                          for layer in current_map.listLayers():                         if config['pattern'] in layer.name:                             layer.visible = True                             enabled_layers.append(layer)                         elif any(crime in layer.name for crime in ["MV Theft", "Burglary", "Robbery", "Sexual"]):                             layer.visible = False                         elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                             layer.visible = True                                          print(f"    ✅ Enabled {len(enabled_layers)} {config['pattern']} layers")                                          # STEP 2: Apply rotation and zoom fixes                     print(f"  🔄 Applying rotation and zoom fixes")                     map_frames = layout.listElements("MAPFRAME_ELEMENT")                     if map_frames:                         camera = map_frames[0].camera                                                  # Fix rotation (north up)                         camera.heading = 0                                                  # Set good scale for city-level view                         camera.scale = 25000                                                  # Center on Hackensack coordinates                         camera.X = -8242906                         camera.Y = 4995946                                                  print(f"    ✅ Camera: heading=0°, scale=25000, centered on Hackensack")                                          # STEP 3: Apply legend fixes (if layout has legend)                     if config['has_legend']:                         print(f"  📋 Applying legend fixes")                         legend_elements = layout.listElements("LEGEND_ELEMENT")                                                  if legend_elements:                             legend = legend_elements[0]                                                          # Make legend visible                             legend.visible = True                                                          # Force all legend items to be visible                             if hasattr(legend, 'items'):                                 visible_items = 0                                 for item in legend.items:                                     if hasattr(item, 'visible'):                                         item.visible = True                                         visible_items += 1                                                                  print(f"    ✅ Legend: {visible_items} items made visible")                                                          # Set legend properties                             try:                                 if hasattr(legend, 'showLayerNames'):                                     legend.showLayerNames = True                                 if hasattr(legend, 'showLabels'):                                     legend.showLabels = True                             except:                                 pass                         else:                             print(f"    ⚠️ No legend elements found in layout")                     else:                         print(f"  ⚠️ This layout has no legend")                                          # STEP 4: Generate export path and filename                     safe_date = test_date.replace('_', '-')                     filename = f"{config['filename']}_{safe_date}.png"                     export_path = os.path.join(main_output, config['subfolder'], filename)                                          print(f"  📄 Target: {filename}")                                          # STEP 5: Export using the working method                     print(f"  📤 Exporting...")                     layout.exportToPNG(export_path)                                          # STEP 6: Verify export success                     if os.path.exists(export_path):                         file_size = os.path.getsize(export_path)                         print(f"  ✅ SUCCESS! {filename} ({file_size:,} bytes)")                         successful += 1                     else:                         print(f"  ❌ FAILED: File not created")                         failed += 1                                          except Exception as e:                     print(f"  ❌ ERROR: {e}")                     failed += 1                  # Final summary         total = successful + failed         print(f"\n" + "=" * 50)         print(f"📊 FINAL PRODUCTION SUMMARY")         print(f"=" * 50)         print(f"✅ Successful exports: {successful}")         print(f"❌ Failed exports: {failed}")         print(f"🎯 Success rate: {(successful/total)*100:.1f}%")         print(f"📁 Output directory: {main_output}")                  if successful > 0:             print(f"\n🎉 PRODUCTION EXPORT COMPLETE!")             print(f"\nYour exports now have:")             print(f"  ✅ Correct orientation (north up, not rotated)")             print(f"  ✅ Visible legends (in layouts that have them)")             print(f"  ✅ Proper filenames:")             print(f"     • MV_Theft_Layout_2025-05-30.png")             print(f"     • Burglary_Auto_Layout_2025-05-30.png")             print(f"     • Burglary_Commercial_Residential_Layout_2025-05-30.png")             print(f"     • Robbery_Layout_2025-05-30.png")             print(f"     • Sexual_Offenses_Layout_2025-05-30.png")             print(f"  ✅ Proper zoom level (focused on Hackensack)")             print(f"  ✅ Organized in crime-specific subfolders")             print(f"  ✅ Only relevant crime data visible per layout")                          print(f"\n📁 Find your exports in:")             print(f"   {main_output}")                      else:             print(f"\n❌ No successful exports - check errors above")              except Exception as e:         print(f"❌ Critical production error: {e}")  # Run the final production export final_production_export()
def diagnose_export_vs_layout():     """Diagnose the difference between what we see in layout vs what exports."""          try:         print("🔍 DIAGNOSING LAYOUT VS EXPORT DIFFERENCES")         print("=" * 50)                  aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Use Burglary Auto (has legend)         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  print(f"🎯 Analyzing: '{test_layout.name}'")                  # Test output         test_output_dir = r"C:\temp"         os.makedirs(test_output_dir, exist_ok=True)                  # BEFORE any changes - capture current state         print(f"\n📸 BEFORE CHANGES:")                  # Check current map frame state         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         if map_frames:             camera = map_frames[0].camera             current_extent = camera.getExtent()                          print(f"  Current Camera:")             print(f"    Heading: {getattr(camera, 'heading', 'unknown')}°")             print(f"    Scale: {getattr(camera, 'scale', 'unknown')}")             print(f"    X: {getattr(camera, 'X', 'unknown')}")             print(f"    Y: {getattr(camera, 'Y', 'unknown')}")             print(f"  Current Extent:")             print(f"    Width: {current_extent.XMax - current_extent.XMin:.0f}")             print(f"    Height: {current_extent.YMax - current_extent.YMin:.0f}")                  # Export BEFORE changes         before_path = os.path.join(test_output_dir, "BEFORE_changes.png")         test_layout.exportToPNG(before_path)                  if os.path.exists(before_path):             file_size = os.path.getsize(before_path)             print(f"  ✅ BEFORE export: {file_size:,} bytes")                  # NOW apply our changes step by step         print(f"\n🔧 APPLYING CHANGES STEP BY STEP:")                  # Step 1: Configure layers ONLY         print(f"  Step 1: Configure layers only")         for layer in current_map.listLayers():             if "Burglary - Auto" in layer.name:                 layer.visible = True             elif any(crime in layer.name for crime in ["MV Theft", "Robbery", "Sexual"]):                 layer.visible = False             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                 layer.visible = True                  # Export after layer changes         layers_path = os.path.join(test_output_dir, "AFTER_layers.png")         test_layout.exportToPNG(layers_path)         print(f"    ✅ After layers: exported")                  # Step 2: Legend changes ONLY         print(f"  Step 2: Legend changes only")         legend_elements = test_layout.listElements("LEGEND_ELEMENT")         if legend_elements:             legend = legend_elements[0]             legend.visible = True                          if hasattr(legend, 'items'):                 for item in legend.items:                     if hasattr(item, 'visible'):                         item.visible = True                 print(f"    ✅ Legend items made visible: {len(legend.items)}")                  # Export after legend changes         legend_path = os.path.join(test_output_dir, "AFTER_legend.png")         test_layout.exportToPNG(legend_path)         print(f"    ✅ After legend: exported")                  # Step 3: Test MINIMAL extent change (don't change coordinates)         print(f"  Step 3: Minimal extent change (no coordinate change)")         if map_frames:             camera = map_frames[0].camera                          # ONLY fix heading, keep everything else the same             original_scale = getattr(camera, 'scale', 25000)             original_x = getattr(camera, 'X', camera.getExtent().XMin + (camera.getExtent().XMax - camera.getExtent().XMin)/2)             original_y = getattr(camera, 'Y', camera.getExtent().YMin + (camera.getExtent().YMax - camera.getExtent().YMin)/2)                          # ONLY fix rotation, keep scale and position similar             camera.heading = 0             # Don't change scale dramatically             # Don't change center coordinates                          print(f"    ✅ Only fixed heading to 0°, kept original scale/position")                  # Export after minimal extent change         minimal_path = os.path.join(test_output_dir, "AFTER_minimal_extent.png")         test_layout.exportToPNG(minimal_path)         print(f"    ✅ After minimal extent: exported")                  # Step 4: Test with ORIGINAL extent but just fix heading         print(f"  Step 4: Restore original extent, fix heading only")         if map_frames:             camera = map_frames[0].camera                          # Reset to original extent             camera.setExtent(current_extent)             # But fix heading             camera.heading = 0                          print(f"    ✅ Restored original extent, heading=0°")                  # Export with original extent         original_extent_path = os.path.join(test_output_dir, "ORIGINAL_extent_fixed_heading.png")         test_layout.exportToPNG(original_extent_path)         print(f"    ✅ Original extent + fixed heading: exported")                  # ANALYSIS: Compare file sizes         print(f"\n📊 EXPORT COMPARISON:")         test_files = [             ("BEFORE changes", before_path),             ("AFTER layers", layers_path),              ("AFTER legend", legend_path),             ("AFTER minimal extent", minimal_path),             ("ORIGINAL extent + fixed heading", original_extent_path)         ]                  for desc, path in test_files:             if os.path.exists(path):                 size = os.path.getsize(path)                 print(f"  {desc}: {size:,} bytes")             else:                 print(f"  {desc}: FILE NOT CREATED")                  print(f"\n💡 RECOMMENDATIONS:")         print(f"  1. Check all exports in: {test_output_dir}")         print(f"  2. Compare BEFORE vs AFTER exports")         print(f"  3. See which step breaks the legend/orientation")         print(f"  4. Use 'ORIGINAL_extent_fixed_heading.png' as baseline")                  # Final test: Create export with MINIMAL changes         print(f"\n🎯 FINAL TEST - MINIMAL CHANGES ONLY:")                  # Reset everything to original state first         camera.setExtent(current_extent)         camera.heading = 0  # Only fix the rotation                  # Make sure legend is visible (this should work)         if legend_elements:             legend = legend_elements[0]             legend.visible = True             if hasattr(legend, 'items'):                 for item in legend.items:                     if hasattr(item, 'visible'):                         item.visible = True                  # Final export         final_path = os.path.join(test_output_dir, "FINAL_minimal_fix.png")         test_layout.exportToPNG(final_path)                  if os.path.exists(final_path):             size = os.path.getsize(final_path)             print(f"  ✅ FINAL minimal fix: {size:,} bytes")             print(f"  📁 Check this file: {final_path}")             print(f"     Should have: correct orientation + legend")              except Exception as e:         print(f"❌ Diagnostic error: {e}")  # Run the diagnostic diagnose_export_vs_layout()

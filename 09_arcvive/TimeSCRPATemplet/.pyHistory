# If we can access your ArcGIS project, let's see what calltype values exist # This would require opening the ArcGIS project, but let's see if we can do it  print("=== QUESTIONS TO DETERMINE CORRECT SQL ===") print("1. In your database/ArcGIS layers, what is the exact text for:") print("   - Motor vehicle theft incidents? (Is it 'Motor Vehicle Theft', 'MV Theft', 'Vehicle Theft', etc.?)") print("   - Auto burglary incidents? (Is it 'Burglary - Auto', 'Auto Burglary', 'Burglary-Auto', etc.?)") print("   - Robbery incidents? (Is it exactly 'Robbery'?)") print("   - Sexual offense incidents? (Is it 'Sexual Offenses', 'Sexual Assault', just 'Sexual', etc.?)") print("\n2. Are there multiple variations for any crime type?") print("3. Is the text case-sensitive? (e.g., 'Robbery' vs 'ROBBERY' vs 'robbery')")
# Let's try to open your ArcGIS project and examine the data import arcpy  try:     # Load your ArcGIS Pro project     aprx = arcpy.mp.ArcGISProject(config.APR_PATH)     print(f"✅ Opened project: {aprx.filePath}")          # Get the map     maps = aprx.listMaps()     if maps:         map_obj = maps[0]         print(f"✅ Found map: {map_obj.name}")                  # Look for crime layers         print("\n=== AVAILABLE LAYERS ===")         for lyr in map_obj.listLayers():             print(f"Layer: {lyr.name}")                      # Try to find a layer with data to examine calltype values         print("\n=== LOOKING FOR CALLTYPE VALUES ===")                  # Look for any layer that might have calltype data         data_layers = []         for lyr in map_obj.listLayers():             if hasattr(lyr, 'supports') and lyr.supports("DATASOURCE"):                 try:                     fields = [f.name for f in arcpy.ListFields(lyr)]                     if 'calltype' in [f.lower() for f in fields]:                         data_layers.append(lyr)                         print(f"Found layer with calltype: {lyr.name}")                 except:                     pass                  # If we found layers with calltype, let's examine the values         if data_layers:             sample_layer = data_layers[0]             print(f"\n=== EXAMINING CALLTYPE VALUES IN: {sample_layer.name} ===")                          # Get unique calltype values             cursor = arcpy.da.SearchCursor(sample_layer, ["calltype"])             calltypes = set()             count = 0             for row in cursor:                 if row[0]:  # If not null                     calltypes.add(row[0])                 count += 1                 if count > 1000:  # Limit to first 1000 records                     break                          print("Unique calltype values found:")             for calltype in sorted(calltypes):                 print(f"  - '{calltype}'")                          else:             print("No layers with 'calltype' field found")                  else:         print("No maps found in project")              # Clean up     del aprx      except Exception as e:     print(f"Error examining ArcGIS data: {e}")
# Let's check if the layers have any data at all try:     aprx = arcpy.mp.ArcGISProject(config.APR_PATH)     map_obj = aprx.listMaps()[0]          print("=== CHECKING LAYER DATA STATUS ===")     for lyr in map_obj.listLayers():         if "MV Theft" in lyr.name or "Burglary" in lyr.name or "Robbery" in lyr.name or "Sexual" in lyr.name:             try:                 # Check if layer supports data operations                 if hasattr(lyr, 'supports') and lyr.supports("DATASOURCE"):                     # Get record count                     result = arcpy.GetCount_management(lyr)                     count = int(result.getOutput(0))                     print(f"{lyr.name}: {count} records")                                          # Check if there's a definition query                     if hasattr(lyr, 'definitionQuery') and lyr.definitionQuery:                         print(f"  Current definition query: {lyr.definitionQuery}")                     else:                         print(f"  No definition query")                 else:                     print(f"{lyr.name}: Cannot access data source")             except Exception as e:                 print(f"{lyr.name}: Error - {e}")          del aprx      except Exception as e:     print(f"Error checking layer data: {e}")

import arcpy  # Simple diagnostic to run directly in ArcGIS Pro def diagnose_current_project():     """Quick diagnostic of current ArcGIS Pro project."""          try:         print("🔍 CURRENT PROJECT DIAGNOSTIC")         print("=" * 40)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         print(f"✅ Using current project")                  # Get layouts         layouts = aprx.listLayouts()         print(f"\n🎨 LAYOUTS ({len(layouts)} found):")         for i, layout in enumerate(layouts):             print(f"  {i+1}. '{layout.name}'")                  # Check each layout for legends         for layout in layouts:             print(f"\n--- Analyzing Layout: '{layout.name}' ---")                          # Get all elements             all_elements = layout.listElements()             print(f"  Total elements: {len(all_elements)}")                          # Look for MainLegend specifically             mainlegend_found = False             legend_elements = []                          for element in all_elements:                 element_name = getattr(element, 'name', 'unnamed')                 element_type = element.__class__.__name__                                  if element_name == "MainLegend":                     mainlegend_found = True                     print(f"  🎯 FOUND MainLegend! (Type: {element_type})")                     print(f"      Visible: {getattr(element, 'visible', 'unknown')}")                                  if 'legend' in element_name.lower():                     legend_elements.append(f"{element_type}: {element_name}")                          if legend_elements:                 print(f"  📋 Legend-related elements:")                 for legend_elem in legend_elements:                     print(f"      {legend_elem}")                          if not mainlegend_found:                 print(f"  ⚠️ MainLegend not found in this layout")                          # Check legend elements by type             typed_legends = layout.listElements("LEGEND_ELEMENT")             if typed_legends:                 print(f"  🏷️ LEGEND_ELEMENT type objects: {len(typed_legends)}")                 for legend in typed_legends:                     legend_name = getattr(legend, 'name', 'unnamed')                     print(f"      {legend_name}")                  # Check maps and layers         maps = aprx.listMaps()         if maps:             current_map = maps[0]             print(f"\n🗺️ MAP: '{current_map.name}'")                          # Look for crime layers             layers = current_map.listLayers()             crime_layers = []             for layer in layers:                 if any(crime in layer.name for crime in ["MV Theft", "Burglary", "Robbery", "Sexual"]):                     crime_layers.append(layer.name)                          print(f"  Crime layers found: {len(crime_layers)}")             for layer_name in crime_layers:                 print(f"    - {layer_name}")                  print(f"\n✅ Diagnostic completed!")              except Exception as e:         print(f"❌ Error: {e}")  # Run the diagnostic diagnose_current_project()
# In ArcGIS Pro Python Command Prompt cd "C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\TimeSCRPATemplet" python Hybrid_Dynamic_Folder_Script.py --mode all --date 2025_05_30
#!/usr/bin/env python3 """ Simple Test Script - Run directly in ArcGIS Pro Python window No command line arguments needed - hardcoded for testing """  import arcpy import os import pandas as pd from datetime import datetime from pathlib import Path  def run_test_export():     """Test export with hardcoded settings."""          try:         arcpy.AddMessage("🚀 Starting Test Export")         arcpy.AddMessage("=" * 50)                  # Hardcoded settings for testing         test_date = "2025_05_30"         export_mode = "all"  # or "specific"                  arcpy.AddMessage(f"📅 Test Date: {test_date}")         arcpy.AddMessage(f"🎯 Mode: {export_mode}")                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         arcpy.AddMessage(f"✅ Using current project")                  # Get map and layouts         maps = aprx.listMaps()         if not maps:             arcpy.AddError("❌ No maps found in project")             return         current_map = maps[0]                  layouts = aprx.listLayouts()         if not layouts:             arcpy.AddError("❌ No layouts found in project")             return                  arcpy.AddMessage(f"✅ Found {len(layouts)} layouts")                  # Create output folder         report_name = get_report_name_from_date(test_date)         folder_name = f"{report_name}_{test_date}"                  base_output_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports"         main_output_path = os.path.join(base_output_path, folder_name)                  # Create folders         if not os.path.exists(main_output_path):             os.makedirs(main_output_path)             arcpy.AddMessage(f"📁 Created main directory: {main_output_path}")                  # Create crime subfolders         crime_subfolders = [             'Motor_Vehicle_Theft',              'Burglary_Auto',              'Burglary_Commercial_Residential',              'Robbery',              'Sexual_Offenses'         ]                  for subfolder in crime_subfolders:             subfolder_path = os.path.join(main_output_path, subfolder)             Path(subfolder_path).mkdir(exist_ok=True)                  # Filter layouts to export (skip Crime Report Legend)         layouts_to_export = []         for layout in layouts:             if layout.name == "Crime Report Legend":                 arcpy.AddMessage(f"⏭️ Skipping: {layout.name}")                 continue             layouts_to_export.append(layout)                  arcpy.AddMessage(f"📋 Will export {len(layouts_to_export)} layouts")                  # Test export each layout         successful_exports = 0         failed_exports = 0                  for i, layout in enumerate(layouts_to_export, 1):             try:                 layout_name = layout.name                 arcpy.AddMessage(f"\n[{i}/{len(layouts_to_export)}] Testing: '{layout_name}'")                                  # Get crime type and subfolder                 crime_type = get_crime_type_from_layout_name(layout_name)                 crime_subfolder = os.path.join(main_output_path, crime_type)                                  # Generate filename                 safe_date = test_date.replace('_', '-')                 filename_mappings = {                     'Motor_Vehicle_Theft': 'MV_Theft_Layout',                     'Burglary_Auto': 'Burglary_Auto_Layout',                     'Burglary_Commercial_Residential': 'Burglary_Commercial_Residential_Layout',                     'Robbery': 'Robbery_Layout',                     'Sexual_Offenses': 'Sexual_Offenses_Layout'                 }                                  filename_prefix = filename_mappings.get(crime_type, f"{crime_type}_Layout")                 filename = f"{filename_prefix}_{safe_date}.png"                 full_path = os.path.join(crime_subfolder, filename)                                  arcpy.AddMessage(f"  📄 Target: {filename}")                 arcpy.AddMessage(f"  📁 Folder: {crime_type}")                                  # Configure legend                 legend_configured = configure_legend_simple(layout)                                  # Try to set optimal extent                 map_frames = layout.listElements("MAPFRAME_ELEMENT")                 if map_frames:                     map_frame = map_frames[0]                     optimal_extent = get_optimal_extent_simple(current_map)                     if optimal_extent:                         try:                             map_frame.camera.setExtent(optimal_extent)                             arcpy.AddMessage(f"  ✅ Set optimal extent")                         except Exception as e:                             arcpy.AddWarning(f"  ⚠️ Could not set extent: {e}")                                  # Refresh and export                 layout.refresh()                 layout.exportToPNG(full_path, resolution=300, width=2000, height=1500)                                  # Check if export worked                 if os.path.exists(full_path):                     file_size = os.path.getsize(full_path)                     arcpy.AddMessage(f"  ✅ Export successful: {file_size:,} bytes")                     successful_exports += 1                 else:                     arcpy.AddError(f"  ❌ Export file not created")                     failed_exports += 1                              except Exception as e:                 arcpy.AddError(f"  ❌ Error: {e}")                 failed_exports += 1                  # Summary         arcpy.AddMessage(f"\n📊 TEST RESULTS:")         arcpy.AddMessage(f"✅ Successful: {successful_exports}")         arcpy.AddMessage(f"❌ Failed: {failed_exports}")         arcpy.AddMessage(f"📁 Output: {main_output_path}")                  if successful_exports > 0:             arcpy.AddMessage(f"🎉 Test completed successfully!")              except Exception as e:         arcpy.AddError(f"❌ Critical error: {e}")  def get_report_name_from_date(target_date_str):     """Get report name from Excel file."""     excel_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\InBox\GIS_Tools\7Day_28Day_Cycle_20250414.xlsx"          try:         df = pd.read_excel(excel_path, sheet_name="7Day_28Day_250414")         df['Report_Due_Date'] = pd.to_datetime(df['Report_Due_Date'])         target_date = pd.to_datetime(target_date_str.replace('_', '-'))         match = df[df['Report_Due_Date'].dt.date == target_date.date()]                  if not match.empty:             return match.iloc[0]['Report_Name']         else:             return f"UNKNOWN_{target_date_str}"     except Exception as e:         return f"ERROR_{target_date_str}"  def get_crime_type_from_layout_name(layout_name):     """Get crime type from layout name."""     layout_mapping = {         'Crime_Reporting_Layout': 'Motor_Vehicle_Theft',         'Burglary - Auto': 'Burglary_Auto',         'Burglary - Comm & Res': 'Burglary_Commercial_Residential',         'Robbery': 'Robbery',         'Sexual Offenses': 'Sexual_Offenses'     }          return layout_mapping.get(layout_name, layout_name.replace(' ', '_').replace('-', '_'))  def configure_legend_simple(layout):     """Simple legend configuration."""     try:         # Find legend elements         legend_elements = layout.listElements("LEGEND_ELEMENT")         if legend_elements:             for legend in legend_elements:                 legend.visible = True                 if hasattr(legend, 'syncLayerVisibility'):                     legend.syncLayerVisibility = False             arcpy.AddMessage(f"  ✅ Configured {len(legend_elements)} legend(s)")             return True         else:             arcpy.AddWarning(f"  ⚠️ No legend found")             return False     except Exception as e:         arcpy.AddWarning(f"  ⚠️ Legend error: {e}")         return False  def get_optimal_extent_simple(current_map):     """Get optimal extent from city boundary."""     try:         for layer in current_map.listLayers():             if any(keyword in layer.name.lower() for keyword in ["city", "boundary", "boundaries"]):                 city_extent = layer.getExtent()                 width = city_extent.XMax - city_extent.XMin                 height = city_extent.YMax - city_extent.YMin                 return arcpy.Extent(                     city_extent.XMin - (width * 0.05),                     city_extent.YMin - (height * 0.05),                     city_extent.XMax + (width * 0.05),                     city_extent.YMax + (height * 0.05)                 )         return None     except:         return None  # Run the test run_test_export()
def debug_single_layout_export():     """Debug a single layout export to see what's happening."""          try:         print("🔍 DEBUG: Single Layout Export Test")         print("=" * 40)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Use the first non-legend layout for testing         test_layout = None         for layout in layouts:             if layout.name != "Crime Report Legend":                 test_layout = layout                 break                  if not test_layout:             print("❌ No suitable layout found for testing")             return                  print(f"🎯 Testing layout: '{test_layout.name}'")                  # Create a simple test output path         test_output_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\DEBUG_TEST"         if not os.path.exists(test_output_dir):             os.makedirs(test_output_dir)                  test_filename = f"DEBUG_{test_layout.name.replace(' ', '_').replace('-', '_')}.png"         test_path = os.path.join(test_output_dir, test_filename)                  print(f"📁 Test output: {test_path}")                  # Step 1: Check layout elements         print(f"\n🔍 Layout Analysis:")         all_elements = test_layout.listElements()         print(f"  Total elements: {len(all_elements)}")                  for element in all_elements:             element_name = getattr(element, 'name', 'unnamed')             element_type = element.__class__.__name__             visible = getattr(element, 'visible', 'unknown')             print(f"    {element_type}: '{element_name}' (visible: {visible})")                  # Step 2: Check map frames         print(f"\n🗺️ Map Frame Analysis:")         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         print(f"  Map frames found: {len(map_frames)}")                  for mf in map_frames:             mf_name = getattr(mf, 'name', 'unnamed')             print(f"    Map frame: '{mf_name}'")             if hasattr(mf, 'camera'):                 print(f"      Has camera: Yes")             else:                 print(f"      Has camera: No")                  # Step 3: Try legend configuration         print(f"\n📋 Legend Configuration Test:")         legend_elements = test_layout.listElements("LEGEND_ELEMENT")         print(f"  Legend elements found: {len(legend_elements)}")                  for legend in legend_elements:             legend_name = getattr(legend, 'name', 'unnamed')             print(f"    Legend: '{legend_name}'")             try:                 legend.visible = True                 print(f"      ✅ Made visible")                 if hasattr(legend, 'syncLayerVisibility'):                     legend.syncLayerVisibility = False                     print(f"      ✅ Disabled sync")             except Exception as e:                 print(f"      ❌ Error configuring: {e}")                  # Step 4: Try extent setting         print(f"\n📐 Extent Configuration Test:")         if map_frames:             map_frame = map_frames[0]             try:                 # Get current extent                 current_extent = map_frame.camera.getExtent()                 print(f"  Current extent: {current_extent.XMin:.2f}, {current_extent.YMin:.2f}, {current_extent.XMax:.2f}, {current_extent.YMax:.2f}")                                  # Try to find city boundary                 city_layer = None                 for layer in current_map.listLayers():                     if any(keyword in layer.name.lower() for keyword in ["city", "boundary", "boundaries"]):                         city_layer = layer                         print(f"  Found boundary layer: {layer.name}")                         break                                  if city_layer:                     city_extent = city_layer.getExtent()                     print(f"  City extent: {city_extent.XMin:.2f}, {city_extent.YMin:.2f}, {city_extent.XMax:.2f}, {city_extent.YMax:.2f}")                                          # Apply small buffer                     width = city_extent.XMax - city_extent.XMin                     height = city_extent.YMax - city_extent.YMin                     buffered_extent = arcpy.Extent(                         city_extent.XMin - (width * 0.05),                         city_extent.YMin - (height * 0.05),                         city_extent.XMax + (width * 0.05),                         city_extent.YMax + (height * 0.05)                     )                                          map_frame.camera.setExtent(buffered_extent)                     print(f"  ✅ Set buffered extent")                 else:                     print(f"  ⚠️ No city boundary layer found")                                  except Exception as e:                 print(f"  ❌ Extent error: {e}")                  # Step 5: Refresh layout         print(f"\n🔄 Layout Refresh Test:")         try:             test_layout.refresh()             print(f"  ✅ Layout refreshed")         except Exception as e:             print(f"  ❌ Refresh error: {e}")                  # Step 6: Try export with basic settings         print(f"\n📤 Export Test:")         try:             print(f"  Attempting export to: {test_path}")             test_layout.exportToPNG(test_path, resolution=200)  # Lower resolution for testing                          # Check if file was created             if os.path.exists(test_path):                 file_size = os.path.getsize(test_path)                 print(f"  ✅ Export successful!")                 print(f"  📊 File size: {file_size:,} bytes")                 print(f"  📁 Location: {test_path}")             else:                 print(f"  ❌ Export file not created")                          except Exception as e:             print(f"  ❌ Export error: {str(e)}")             print(f"  Error type: {type(e).__name__}")                          # Try alternative export method             try:                 print(f"  🔄 Trying alternative export...")                 test_layout.exportToPNG(test_path)  # Minimal parameters                 if os.path.exists(test_path):                     print(f"  ✅ Alternative export worked!")                 else:                     print(f"  ❌ Alternative export also failed")             except Exception as e2:                 print(f"  ❌ Alternative export error: {e2}")                  print(f"\n✅ Debug test completed!")              except Exception as e:         print(f"❌ Critical debug error: {e}")  # Run the debug test debug_single_layout_export()
def test_layout_with_legend():     """Test export using a layout that actually has a legend."""          try:         print("🔧 TESTING WITH LAYOUT THAT HAS LEGEND")         print("=" * 45)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Use 'Burglary - Auto' layout (we know it has a legend)         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  if not test_layout:             print("❌ Could not find 'Burglary - Auto' layout")             return                  print(f"🎯 Testing layout: '{test_layout.name}' (known to have legend)")                  # Test output         test_output_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\DEBUG_TEST"         test_filename = f"WITH_LEGEND_{test_layout.name.replace(' ', '_').replace('-', '_')}.png"         test_path = os.path.join(test_output_dir, test_filename)                  print(f"📁 Output: {test_filename}")                  # Check legend elements in this layout         print(f"\n📋 LEGEND CHECK:")         legend_elements = test_layout.listElements("LEGEND_ELEMENT")         print(f"  Legend elements found: {len(legend_elements)}")                  if legend_elements:             for i, legend in enumerate(legend_elements):                 legend_name = getattr(legend, 'name', 'unnamed')                 print(f"    Legend {i+1}: '{legend_name}'")                                  # Configure legend                 try:                     legend.visible = True                     print(f"      ✅ Made visible")                                          if hasattr(legend, 'syncLayerVisibility'):                         legend.syncLayerVisibility = False                         print(f"      ✅ Disabled sync")                                          if hasattr(legend, 'items'):                         print(f"      📊 Has {len(legend.items)} legend items")                                                  # Show all legend items                         for item in legend.items:                             if hasattr(item, 'visible'):                                 item.visible = True                                 item_name = getattr(item, 'name', 'unnamed')                                 print(f"        ✅ Showing: {item_name}")                                  except Exception as e:                     print(f"      ❌ Legend config error: {e}")                  # FIXED extent method         print(f"\n📐 ZOOM FIX (with correct method):")         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")                  if map_frames:             map_frame = map_frames[0]                          # Get current extent             try:                 current_extent = map_frame.camera.getExtent()                 print(f"  📏 Current extent width: {current_extent.XMax - current_extent.XMin:.0f}")                 print(f"  📏 Current extent height: {current_extent.YMax - current_extent.YMin:.0f}")                                  # Create a smaller extent (zoom in more)                 center_x = (current_extent.XMin + current_extent.XMax) / 2                 center_y = (current_extent.YMin + current_extent.YMax) / 2                                  # Make extent 60% of current size (zoom in more)                 current_width = current_extent.XMax - current_extent.XMin                 current_height = current_extent.YMax - current_extent.YMin                                  new_width = current_width * 0.6  # 60% = more zoomed in                 new_height = current_height * 0.6                                  zoomed_extent = arcpy.Extent(                     center_x - new_width/2,                     center_y - new_height/2,                     center_x + new_width/2,                     center_y + new_height/2                 )                                  map_frame.camera.setExtent(zoomed_extent)                 print(f"  ✅ Zoomed in to 60% of original extent")                 print(f"  📏 New extent width: {new_width:.0f}")                 print(f"  📏 New extent height: {new_height:.0f}")                              except Exception as e:                 print(f"  ❌ Extent error: {e}")                  # Show/hide appropriate layers for Burglary - Auto         print(f"\n🔗 LAYER CONFIGURATION:")         layers_configured = 0         for layer in current_map.listLayers():             if "Burglary - Auto" in layer.name:                 layer.visible = True                 layers_configured += 1                 print(f"  ✅ Enabled: {layer.name}")             elif any(crime in layer.name for crime in ["MV Theft", "Robbery", "Sexual"]):                 layer.visible = False                 print(f"  ❌ Disabled: {layer.name}")             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                 layer.visible = True                 print(f"  ✅ Base layer: {layer.name}")                  print(f"  📊 Configured {layers_configured} Burglary - Auto layers")                  # Export         print(f"\n📤 EXPORT:")         try:             test_layout.exportToPNG(test_path, resolution=300, width=2000, height=1500)                          if os.path.exists(test_path):                 file_size = os.path.getsize(test_path)                 print(f"  ✅ Export successful!")                 print(f"  📊 File size: {file_size:,} bytes")                 print(f"  📁 Location: {test_path}")                 print(f"\n🎉 This export should have BOTH legend AND better zoom!")             else:                 print(f"  ❌ Export failed")                          except Exception as e:             print(f"  ❌ Export error: {e}")              except Exception as e:         print(f"❌ Critical error: {e}")  # Run the test with a layout that has a legend test_layout_with_legend()
def test_final_export_fix():     """Final test with corrected export parameters and legend item fix."""          try:         print("🔧 FINAL EXPORT FIX TEST")         print("=" * 35)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Use 'Burglary - Auto' layout         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  print(f"🎯 Testing layout: '{test_layout.name}'")                  # Test output         test_output_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\DEBUG_TEST"         test_filename = f"FINAL_FIX_{test_layout.name.replace(' ', '_').replace('-', '_')}.png"         test_path = os.path.join(test_output_dir, test_filename)                  print(f"📁 Output: {test_filename}")                  # Configure layers for Burglary - Auto         print(f"\n🔗 LAYER SETUP:")         burglary_layers = []         for layer in current_map.listLayers():             if "Burglary - Auto" in layer.name:                 layer.visible = True                 burglary_layers.append(layer)                 print(f"  ✅ Enabled: {layer.name}")             elif any(crime in layer.name for crime in ["MV Theft", "Robbery", "Sexual"]):                 layer.visible = False             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                 layer.visible = True                  print(f"  📊 {len(burglary_layers)} Burglary - Auto layers enabled")                  # LEGEND FIX: Force legend to recognize visible layers         print(f"\n📋 LEGEND REPAIR:")         legend_elements = test_layout.listElements("LEGEND_ELEMENT")                  if legend_elements:             legend = legend_elements[0]             print(f"  Working with legend: '{getattr(legend, 'name', 'unnamed')}'")                          # Make legend visible             legend.visible = True                          # CRITICAL: Re-associate legend with map             try:                 if hasattr(legend, 'map'):                     legend.map = current_map                     print(f"  ✅ Re-associated legend with map")             except Exception as e:                 print(f"  ⚠️ Could not re-associate map: {e}")                          # Try to add layers to legend manually             try:                 if hasattr(legend, 'addItem'):                     for layer in burglary_layers:                         try:                             legend.addItem(layer)                             print(f"  ✅ Added to legend: {layer.name}")                         except Exception as e:                             print(f"  ⚠️ Could not add {layer.name}: {e}")                 elif hasattr(legend, 'updateItem'):                     for layer in burglary_layers:                         try:                             legend.updateItem(layer)                             print(f"  ✅ Updated in legend: {layer.name}")                         except Exception as e:                             print(f"  ⚠️ Could not update {layer.name}: {e}")             except Exception as e:                 print(f"  ⚠️ Legend update error: {e}")                          # Check legend items after update             if hasattr(legend, 'items'):                 print(f"  📊 Legend now has {len(legend.items)} items")                 for item in legend.items:                     item_name = getattr(item, 'name', 'unnamed')                     if hasattr(item, 'visible'):                         item.visible = True                     print(f"    - {item_name}")                  # Set zoom extent         print(f"\n📐 ZOOM SETUP:")         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         if map_frames:             map_frame = map_frames[0]             try:                 current_extent = map_frame.camera.getExtent()                 center_x = (current_extent.XMin + current_extent.XMax) / 2                 center_y = (current_extent.YMin + current_extent.YMax) / 2                                  # Zoom to 50% for even tighter view                 current_width = current_extent.XMax - current_extent.XMin                 current_height = current_extent.YMax - current_extent.YMin                                  new_width = current_width * 0.5                 new_height = current_height * 0.5                                  zoomed_extent = arcpy.Extent(                     center_x - new_width/2,                     center_y - new_height/2,                     center_x + new_width/2,                     center_y + new_height/2                 )                                  map_frame.camera.setExtent(zoomed_extent)                 print(f"  ✅ Set 50% zoom (tighter view)")                              except Exception as e:                 print(f"  ❌ Zoom error: {e}")                  # CORRECTED EXPORT: Remove width/height parameters         print(f"\n📤 EXPORT (corrected parameters):")         try:             # Method 1: Basic export             test_layout.exportToPNG(test_path, resolution=300)                          if os.path.exists(test_path):                 file_size = os.path.getsize(test_path)                 print(f"  ✅ Export successful!")                 print(f"  📊 File size: {file_size:,} bytes")                 print(f"  📁 Location: {test_path}")                 print(f"\n🎉 Check this export - should have legend and tight zoom!")             else:                 print(f"  ❌ Export file not created")                          except Exception as e:             print(f"  ❌ Export error: {e}")                          # Fallback: Try minimal parameters             try:                 print(f"  🔄 Trying minimal export...")                 test_layout.exportToPNG(test_path)                 if os.path.exists(test_path):                     print(f"  ✅ Minimal export worked!")                 else:                     print(f"  ❌ Minimal export also failed")             except Exception as e2:                 print(f"  ❌ Minimal export error: {e2}")              except Exception as e:         print(f"❌ Critical error: {e}")  # Run the final fix test test_final_export_fix()
def export_all_layouts_fixed():     """Export all crime layouts with working legend and zoom fixes."""          try:         print("🚀 EXPORTING ALL LAYOUTS WITH FIXES")         print("=" * 45)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Create output folder structure         test_date = "2025_05_30"         report_name = get_report_name_from_date(test_date)         folder_name = f"{report_name}_{test_date}"                  base_output_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports"         main_output_path = os.path.join(base_output_path, folder_name)                  print(f"📁 Output folder: {folder_name}")                  # Ensure main folder exists         if not os.path.exists(main_output_path):             os.makedirs(main_output_path)                  # Create crime subfolders         crime_subfolders = {             'Crime_Reporting_Layout': 'Motor_Vehicle_Theft',             'Burglary - Auto': 'Burglary_Auto',              'Burglary - Comm & Res': 'Burglary_Commercial_Residential',             'Robbery': 'Robbery',             'Sexual Offenses': 'Sexual_Offenses'         }                  for subfolder in crime_subfolders.values():             subfolder_path = os.path.join(main_output_path, subfolder)             os.makedirs(subfolder_path, exist_ok=True)                  # Crime type to layer mapping         crime_layer_patterns = {             'Crime_Reporting_Layout': 'MV Theft',             'Burglary - Auto': 'Burglary - Auto',             'Burglary - Comm & Res': 'Burglary - Comm & Res',              'Robbery': 'Robbery',             'Sexual Offenses': 'Sexual Offenses'         }                  # Filename mappings         filename_mappings = {             'Motor_Vehicle_Theft': 'MV_Theft_Layout',             'Burglary_Auto': 'Burglary_Auto_Layout',             'Burglary_Commercial_Residential': 'Burglary_Commercial_Residential_Layout',             'Robbery': 'Robbery_Layout',             'Sexual_Offenses': 'Sexual_Offenses_Layout'         }                  # Process each layout (skip Crime Report Legend)         successful_exports = 0         failed_exports = 0                  for layout in layouts:             layout_name = layout.name                          # Skip the legend-only layout             if layout_name == "Crime Report Legend":                 print(f"⏭️ Skipping: {layout_name}")                 continue                          print(f"\n[{successful_exports + failed_exports + 1}] Processing: '{layout_name}'")                          try:                 # Get crime type and output info                 crime_type = crime_subfolders.get(layout_name, layout_name.replace(' ', '_').replace('-', '_'))                 crime_subfolder = os.path.join(main_output_path, crime_type)                                  # Generate proper filename                 safe_date = test_date.replace('_', '-')                 filename_prefix = filename_mappings.get(crime_type, f"{crime_type}_Layout")                 filename = f"{filename_prefix}_{safe_date}.png"                 export_path = os.path.join(crime_subfolder, filename)                                  print(f"  📄 Target: {filename}")                 print(f"  📁 Folder: {crime_type}")                                  # Configure layers for this crime type                 if layout_name in crime_layer_patterns:                     layer_pattern = crime_layer_patterns[layout_name]                                          # Hide all crime layers first                     for layer in current_map.listLayers():                         if any(crime in layer.name for crime in ["MV Theft", "Burglary", "Robbery", "Sexual"]):                             layer.visible = False                                          # Enable layers for this crime type                     enabled_layers = []                     for layer in current_map.listLayers():                         if layer_pattern in layer.name:                             layer.visible = True                             enabled_layers.append(layer)                         elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                             layer.visible = True                                          print(f"  🔗 Enabled {len(enabled_layers)} {layer_pattern} layers")                                  # Fix legend (if layout has one)                 legend_elements = layout.listElements("LEGEND_ELEMENT")                 if legend_elements:                     legend = legend_elements[0]                     legend.visible = True                                          # Re-associate with map and add visible layers                     try:                         if hasattr(legend, 'map'):                             legend.map = current_map                                                  if hasattr(legend, 'addItem') and enabled_layers:                             for layer in enabled_layers:                                 try:                                     legend.addItem(layer)                                 except:                                     pass                                                  print(f"  ✅ Legend configured")                     except Exception as e:                         print(f"  ⚠️ Legend warning: {e}")                 else:                     print(f"  ⚠️ No legend in this layout")                                  # Set tight zoom                 map_frames = layout.listElements("MAPFRAME_ELEMENT")                 if map_frames:                     map_frame = map_frames[0]                     try:                         current_extent = map_frame.camera.getExtent()                         center_x = (current_extent.XMin + current_extent.XMax) / 2                         center_y = (current_extent.YMin + current_extent.YMax) / 2                                                  # 50% zoom for tight view                         current_width = current_extent.XMax - current_extent.XMin                         current_height = current_extent.YMax - current_extent.YMin                                                  new_width = current_width * 0.5                         new_height = current_height * 0.5                                                  zoomed_extent = arcpy.Extent(                             center_x - new_width/2,                             center_y - new_height/2,                             center_x + new_width/2,                             center_y + new_height/2                         )                                                  map_frame.camera.setExtent(zoomed_extent)                         print(f"  ✅ Set tight zoom")                     except Exception as e:                         print(f"  ⚠️ Zoom warning: {e}")                                  # Export                 layout.exportToPNG(export_path, resolution=300)                                  # Verify export                 if os.path.exists(export_path):                     file_size = os.path.getsize(export_path)                     print(f"  ✅ Export successful: {file_size:,} bytes")                     successful_exports += 1                 else:                     print(f"  ❌ Export file not created")                     failed_exports += 1                              except Exception as e:                 print(f"  ❌ Error: {e}")                 failed_exports += 1                  # Final summary         total_layouts = successful_exports + failed_exports         print(f"\n📊 FINAL RESULTS:")         print(f"✅ Successful exports: {successful_exports}")         print(f"❌ Failed exports: {failed_exports}")         print(f"📁 Output folder: {main_output_path}")         print(f"🎯 Success rate: {(successful_exports/total_layouts)*100:.1f}%")                  if successful_exports > 0:             print(f"\n🎉 Production export completed!")             print(f"Check your exports - they should have:")             print(f"  ✅ Visible legends")             print(f"  ✅ Proper filenames (MV_Theft_Layout_2025-05-30.png, etc.)")             print(f"  ✅ Tight zoom on Hackensack")             print(f"  ✅ Correct crime-specific subfolders")              except Exception as e:         print(f"❌ Critical error: {e}")  def get_report_name_from_date(target_date_str):     """Get report name from Excel file."""     excel_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\InBox\GIS_Tools\7Day_28Day_Cycle_20250414.xlsx"          try:         import pandas as pd         df = pd.read_excel(excel_path, sheet_name="7Day_28Day_250414")         df['Report_Due_Date'] = pd.to_datetime(df['Report_Due_Date'])         target_date = pd.to_datetime(target_date_str.replace('_', '-'))         match = df[df['Report_Due_Date'].dt.date == target_date.date()]                  if not match.empty:             return match.iloc[0]['Report_Name']         else:             return f"UNKNOWN_{target_date_str}"     except Exception as e:         return f"ERROR_{target_date_str}"  # Run the complete export export_all_layouts_fixed()
def fix_legend_and_rotation():     """Final fix for legend visibility and map rotation issues."""          try:         print("🔧 FIXING LEGEND VISIBILITY AND MAP ROTATION")         print("=" * 50)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Test with one layout first - Burglary Auto (known to have legend)         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  print(f"🎯 Testing fixes with: '{test_layout.name}'")                  # Test output         test_output_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\DEBUG_TEST"         test_filename = f"ROTATION_LEGEND_FIX_{test_layout.name.replace(' ', '_').replace('-', '_')}.png"         test_path = os.path.join(test_output_dir, test_filename)                  # Configure layers for Burglary - Auto         print(f"\n🔗 LAYER SETUP:")         for layer in current_map.listLayers():             if "Burglary - Auto" in layer.name:                 layer.visible = True                 print(f"  ✅ Enabled: {layer.name}")             elif any(crime in layer.name for crime in ["MV Theft", "Robbery", "Sexual"]):                 layer.visible = False             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                 layer.visible = True                  # ROTATION FIX: Set proper map frame rotation and extent         print(f"\n🔄 ROTATION FIX:")         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         if map_frames:             map_frame = map_frames[0]                          # Fix 1: Reset map frame rotation to 0             try:                 if hasattr(map_frame, 'camera'):                     camera = map_frame.camera                                          # Reset rotation to 0 degrees (north up)                     if hasattr(camera, 'heading'):                         camera.heading = 0                         print(f"  ✅ Reset camera heading to 0°")                                          # Set proper scale and center on Hackensack                     if hasattr(camera, 'scale'):                         # Set a reasonable scale for city-level view                         camera.scale = 25000  # Adjust this value as needed                         print(f"  ✅ Set scale to 25000")                                          # Center on Hackensack coordinates (approximate)                     if hasattr(camera, 'X') and hasattr(camera, 'Y'):                         # Hackensack, NJ approximate coordinates (Web Mercator)                         hackensack_x = -8242906  # Approximate                         hackensack_y = 4995946   # Approximate                                                  camera.X = hackensack_x                         camera.Y = hackensack_y                         print(f"  ✅ Centered on Hackensack")                              except Exception as e:                 print(f"  ⚠️ Camera adjustment error: {e}")                          # Fix 2: Alternative extent method             try:                 # Get city boundary extent and ensure proper orientation                 city_layer = None                 for layer in current_map.listLayers():                     if "City" in layer.name and "Bound" in layer.name:                         city_layer = layer                         break                                  if city_layer:                     # Use a fixed extent based on your area                     # These coordinates should be adjusted to your specific area                     hackensack_extent = arcpy.Extent(                         -8245000,  # XMin - adjust as needed                         4993000,   # YMin - adjust as needed                           -8240000,  # XMax - adjust as needed                         4998000    # YMax - adjust as needed                     )                                          map_frame.camera.setExtent(hackensack_extent)                     print(f"  ✅ Set fixed Hackensack extent")                              except Exception as e:                 print(f"  ⚠️ Extent setting error: {e}")                  # LEGEND VISIBILITY FIX: Advanced legend configuration         print(f"\n📋 ADVANCED LEGEND FIX:")         legend_elements = test_layout.listElements("LEGEND_ELEMENT")                  if legend_elements:             legend = legend_elements[0]             print(f"  Working with legend: '{getattr(legend, 'name', 'unnamed')}'")                          try:                 # Make legend highly visible                 legend.visible = True                 print(f"  ✅ Made legend visible")                                  # Force legend to front                 if hasattr(legend, 'sendToFront'):                     legend.sendToFront()                     print(f"  ✅ Sent legend to front")                                  # Ensure legend is properly sized and positioned                 if hasattr(legend, 'elementHeight') and hasattr(legend, 'elementWidth'):                     # Make sure legend has reasonable size                     if legend.elementHeight < 1:                         legend.elementHeight = 2.0  # inches                     if legend.elementWidth < 1:                         legend.elementWidth = 1.5   # inches                     print(f"  ✅ Set legend size: {legend.elementWidth:.1f} x {legend.elementHeight:.1f}")                                  # Reset legend properties                 if hasattr(legend, 'syncLayerVisibility'):                     legend.syncLayerVisibility = True  # Try enabling sync                     print(f"  ✅ Enabled syncLayerVisibility")                                  # Force legend refresh with visible layers                 if hasattr(legend, 'updateItem'):                     visible_burglary_layers = [layer for layer in current_map.listLayers()                                               if layer.visible and "Burglary - Auto" in layer.name]                     for layer in visible_burglary_layers:                         try:                             legend.updateItem(layer)                             print(f"  ✅ Updated legend for: {layer.name}")                         except Exception as e:                             print(f"  ⚠️ Could not update {layer.name}: {e}")                                  # Check final legend state                 if hasattr(legend, 'items'):                     print(f"  📊 Final legend items: {len(legend.items)}")                     for item in legend.items:                         item_name = getattr(item, 'name', 'unnamed')                         item_visible = getattr(item, 'visible', 'unknown')                         print(f"    - {item_name} (visible: {item_visible})")                              except Exception as e:                 print(f"  ❌ Legend configuration error: {e}")                  # EXPORT WITH SPECIFIC SETTINGS         print(f"\n📤 EXPORT WITH FIXES:")         try:             # Export with specific DPI and quality settings             test_layout.exportToPNG(                 test_path,                  resolution=300,                 transparent_background=False,                 world_file=False             )                          if os.path.exists(test_path):                 file_size = os.path.getsize(test_path)                 print(f"  ✅ Export successful!")                 print(f"  📊 File size: {file_size:,} bytes")                 print(f"  📁 Location: {test_path}")                 print(f"\n🎉 CHECK THIS EXPORT:")                 print(f"     - Should have CORRECT rotation (north up)")                 print(f"     - Should have VISIBLE legend")                 print(f"     - Should be properly centered on Hackensack")             else:                 print(f"  ❌ Export file not created")                          except Exception as e:             print(f"  ❌ Export error: {e}")                          # Try basic export as fallback             try:                 print(f"  🔄 Trying basic export...")                 test_layout.exportToPNG(test_path)                 if os.path.exists(test_path):                     print(f"  ✅ Basic export worked!")             except Exception as e2:                 print(f"  ❌ Basic export also failed: {e2}")              except Exception as e:         print(f"❌ Critical error: {e}")  # Run the rotation and legend fix fix_legend_and_rotation()
def final_legend_rotation_fix():     """Final corrected fix for legend visibility and map rotation."""          try:         print("🔧 FINAL CORRECTED FIX")         print("=" * 35)                  # Get current project         aprx = arcpy.mp.ArcGISProject("CURRENT")         current_map = aprx.listMaps()[0]         layouts = aprx.listLayouts()                  # Test with Burglary Auto layout         test_layout = None         for layout in layouts:             if layout.name == "Burglary - Auto":                 test_layout = layout                 break                  print(f"🎯 Testing: '{test_layout.name}'")                  # Test output         test_output_dir = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\DEBUG_TEST"         test_filename = f"FINAL_CORRECTED_{test_layout.name.replace(' ', '_').replace('-', '_')}.png"         test_path = os.path.join(test_output_dir, test_filename)                  # Configure layers         print(f"\n🔗 LAYER SETUP:")         enabled_layers = []         for layer in current_map.listLayers():             if "Burglary - Auto" in layer.name:                 layer.visible = True                 enabled_layers.append(layer)                 print(f"  ✅ Enabled: {layer.name}")             elif any(crime in layer.name for crime in ["MV Theft", "Robbery", "Sexual"]):                 layer.visible = False             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                 layer.visible = True                  # ROTATION FIX (same as before)         print(f"\n🔄 ROTATION FIX:")         map_frames = test_layout.listElements("MAPFRAME_ELEMENT")         if map_frames:             map_frame = map_frames[0]                          try:                 camera = map_frame.camera                 camera.heading = 0      # North up                 camera.scale = 25000    # Good scale for city view                                  # Center on Hackensack                 camera.X = -8242906                 camera.Y = 4995946                                  print(f"  ✅ Camera configured: heading=0°, scale=25000")                              except Exception as e:                 print(f"  ⚠️ Camera error: {e}")                  # LEGEND FIX - Force all legend items visible         print(f"\n📋 LEGEND VISIBILITY FIX:")         legend_elements = test_layout.listElements("LEGEND_ELEMENT")                  if legend_elements:             legend = legend_elements[0]                          # Make legend visible             legend.visible = True                          # CRITICAL: Force ALL legend items to be visible             if hasattr(legend, 'items'):                 print(f"  📊 Processing {len(legend.items)} legend items...")                                  visible_count = 0                 for item in legend.items:                     try:                         # Force each item to be visible                         if hasattr(item, 'visible'):                             item.visible = True                             visible_count += 1                                                      # Also try other visibility properties                         if hasattr(item, 'showLabels'):                             item.showLabels = True                         if hasattr(item, 'showLayerName'):                             item.showLayerName = True                         if hasattr(item, 'showHeading'):                             item.showHeading = True                                                      item_name = getattr(item, 'name', 'unnamed')                         print(f"    ✅ Forced visible: {item_name}")                                              except Exception as e:                         print(f"    ⚠️ Item error: {e}")                                  print(f"  ✅ Made {visible_count} legend items visible")                          # Additional legend properties             try:                 # Ensure legend shows layer names and symbols                 if hasattr(legend, 'showLayerNames'):                     legend.showLayerNames = True                 if hasattr(legend, 'showLabels'):                     legend.showLabels = True                 if hasattr(legend, 'showSymbols'):                     legend.showSymbols = True                                      print(f"  ✅ Set legend display properties")                              except Exception as e:                 print(f"  ⚠️ Legend properties error: {e}")                  # CORRECTED EXPORT (remove problematic parameters)         print(f"\n📤 CORRECTED EXPORT:")         try:             # Use only basic, supported parameters             test_layout.exportToPNG(test_path, resolution=300)                          if os.path.exists(test_path):                 file_size = os.path.getsize(test_path)                 print(f"  ✅ Export successful!")                 print(f"  📊 File size: {file_size:,} bytes")                 print(f"  📁 Location: {test_path}")                                  print(f"\n🎉 CHECK THIS FINAL EXPORT:")                 print(f"     ✅ Should be correctly oriented (north up)")                 print(f"     ✅ Should show legend with Burglary - Auto layers")                 print(f"     ✅ Should be centered on Hackensack at proper scale")                                  return True                              else:                 print(f"  ❌ Export file not created")                 return False                          except Exception as e:             print(f"  ❌ Export error: {e}")             return False              except Exception as e:         print(f"❌ Critical error: {e}")         return False  # Test the final fix if final_legend_rotation_fix():     print(f"\n🚀 FIXES SUCCESSFUL! Ready to apply to all layouts.")          # If test successful, run production version     def apply_fixes_to_all_layouts():         """Apply working fixes to all crime layouts."""                  try:             print(f"\n🔥 APPLYING FIXES TO ALL LAYOUTS")             print("=" * 40)                          aprx = arcpy.mp.ArcGISProject("CURRENT")             current_map = aprx.listMaps()[0]             layouts = aprx.listLayouts()                          # Output setup             test_date = "2025_05_30"             base_output = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports"             main_output = os.path.join(base_output, f"FIXED_EXPORTS_{test_date}")                          if not os.path.exists(main_output):                 os.makedirs(main_output)                          # Crime configurations             crime_configs = {                 'Crime_Reporting_Layout': {                     'pattern': 'MV Theft',                     'subfolder': 'Motor_Vehicle_Theft',                     'filename': 'MV_Theft_Layout'                 },                 'Burglary - Auto': {                     'pattern': 'Burglary - Auto',                     'subfolder': 'Burglary_Auto',                      'filename': 'Burglary_Auto_Layout'                 },                 'Burglary - Comm & Res': {                     'pattern': 'Burglary - Comm & Res',                     'subfolder': 'Burglary_Commercial_Residential',                     'filename': 'Burglary_Commercial_Residential_Layout'                 },                 'Robbery': {                     'pattern': 'Robbery',                     'subfolder': 'Robbery',                     'filename': 'Robbery_Layout'                 },                 'Sexual Offenses': {                     'pattern': 'Sexual Offenses',                     'subfolder': 'Sexual_Offenses',                     'filename': 'Sexual_Offenses_Layout'                 }             }                          # Create subfolders             for config in crime_configs.values():                 subfolder_path = os.path.join(main_output, config['subfolder'])                 os.makedirs(subfolder_path, exist_ok=True)                          successful = 0             failed = 0                          # Process each layout             for layout in layouts:                 if layout.name in crime_configs:                     config = crime_configs[layout.name]                                          print(f"\n[{successful + failed + 1}] Processing: '{layout.name}'")                                          try:                         # Configure layers                         for layer in current_map.listLayers():                             if config['pattern'] in layer.name:                                 layer.visible = True                             elif any(crime in layer.name for crime in ["MV Theft", "Burglary", "Robbery", "Sexual"]):                                 layer.visible = False                             elif any(base in layer.name for base in ["City", "OpenStreetMap", "Canvas", "Streets"]):                                 layer.visible = True                                                  # Apply rotation fix                         map_frames = layout.listElements("MAPFRAME_ELEMENT")                         if map_frames:                             camera = map_frames[0].camera                             camera.heading = 0                             camera.scale = 25000                             camera.X = -8242906                             camera.Y = 4995946                                                  # Apply legend fix                         legend_elements = layout.listElements("LEGEND_ELEMENT")                         if legend_elements:                             legend = legend_elements[0]                             legend.visible = True                                                          if hasattr(legend, 'items'):                                 for item in legend.items:                                     if hasattr(item, 'visible'):                                         item.visible = True             
'):                 legend.syncLayerVisibility = True                 print(f"    ✅ Enabled syncLayerVisibility")                  test2_path = os.path.join(test_output, "legend_test2_sync_enabled.png")         test_layout.exportToPNG(test2_path)         print(f"    ✅ Exported: legend_test2_sync_enabled.png")                  # Approach 3: Try refreshing legend with map         print(f"  Approach 3: Refresh legend with current map")         if legend_elements:             legend = legend_elements[0]             try:                 if hasattr(legend, 'map'):                     legend.map = current_map                     print(f"    ✅ Re-associated legend with map")                                  # Try to refresh/update legend                 if hasattr(legend, 'refresh'):                     legend.refresh()                     print(f"    ✅ Refreshed legend")                              except Exception as e:                 print(f"    ⚠️ Refresh error: {e}")                  test3_path = os.path.join(test_output, "legend_test3_refreshed.png")         test_layout.exportToPNG(test3_path)         print(f"    ✅ Exported: legend_test3_refreshed.png")                  # Approach 4: Manual legend item management         print(f"  Approach 4: Manual legend item management")         if legend_elements:             legend = legend_elements[0]             if hasattr(legend, 'items'):                 # Remove all items first                 try:                     for item in list(legend.items):                         if hasattr(legend, 'removeItem'):                             legend.removeItem(item)                     print(f"    ✅ Cleared existing legend items")                 except Exception as e:                     print(f"    ⚠️ Could not clear items: {e}")                                  # Add visible Burglary layers manually                 try:                     if hasattr(legend, 'addItem'):                         for layer in current_map.listLayers
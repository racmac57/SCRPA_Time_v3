# Test just the core folder creation functionality import pandas as pd import os from pathlib import Path import sys  def get_report_name_from_date(target_date_str):     excel_path = r"C:\Users\carucci_r\OneDrive - City of Hackensack\InBox\GIS_Tools\7Day_28Day_Cycle_20250414.xlsx"     try:         df = pd.read_excel(excel_path, sheet_name="7Day_28Day_250414")         df['Report_Due_Date'] = pd.to_datetime(df['Report_Due_Date'])         target_date = pd.to_datetime(target_date_str.replace('_', '-'))         match = df[df['Report_Due_Date'].dt.date == target_date.date()]                  if not match.empty:             report_name = match.iloc[0]['Report_Name']             print(f"✅ Found Report_Name: {report_name} for date: {target_date_str}")             return report_name         else:             print(f"❌ No matching Report_Name for date: {target_date_str}")             return f"UNKNOWN_{target_date_str}"     except Exception as e:         print(f"❌ Error: {e}")         return f"ERROR_{target_date_str}"  def get_crime_type_subfolder(crime_type):     crime_type_mapping = {         'mv theft': 'Motor_Vehicle_Theft',         'burglary - auto': 'Burglary_Auto',         'burglary - comm & res': 'Burglary_Commercial_Residential',         'robbery': 'Robbery',         'sexual offenses': 'Sexual_Offenses',     }          crime_lower = crime_type.lower().strip()     for key, value in crime_type_mapping.items():         if key in crime_lower:             return value          clean_name = crime_type.replace(' - ', '_').replace(' & ', '_').replace(' ', '_')     return clean_name  def create_dynamic_folder_structure(base_folder, date_str, crime_types):     try:         report_name = get_report_name_from_date(date_str)         main_folder_name = f"{report_name}_{date_str}"         main_folder_path = os.path.join(base_folder, main_folder_name)                  # Create main folder         Path(main_folder_path).mkdir(parents=True, exist_ok=True)         print(f"✅ Created main folder: {main_folder_path}")                  # Create subfolders         for crime_type in crime_types:             subfolder_name = get_crime_type_subfolder(crime_type)             subfolder_path = os.path.join(main_folder_path, subfolder_name)             Path(subfolder_path).mkdir(parents=True, exist_ok=True)             print(f"✅ Created subfolder: {subfolder_name}")                  return main_folder_path     except Exception as e:         print(f"❌ Error creating folders: {e}")         return None  # Test the functionality print("🚀 Testing dynamic folder creation...")  crime_types = [     "MV Theft",     "Burglary - Auto",      "Burglary - Comm & Res",     "Robbery",     "Sexual Offenses" ]  base_folder = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports" date_str = "2025_05_27"  result = create_dynamic_folder_structure(base_folder, date_str, crime_types)  if result:     print(f"🎉 SUCCESS! Folders created at: {result}") else:     print("❌ FAILED to create folders")

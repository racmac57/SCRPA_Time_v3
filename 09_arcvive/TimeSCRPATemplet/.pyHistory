# Let's create a wrapper that processes the raw CSV data for charts def create_processed_data_for_charts(crime_type):     """     Convert raw CSV data to the format charts expect.     """     import pandas as pd     from datetime import datetime          # File paths     table_dir = r"C:\GIS_Data\SCRPA\tables"     sanitized = crime_type.replace(" ", "_").replace("&", "And").replace("-", "_")          # Try different filename patterns     possible_files = [         f"{sanitized}.csv",         f"{crime_type.replace(' ', '_').replace('&', 'And')}.csv",         f"{crime_type.replace(' ', '_')}.csv"     ]          csv_path = None     for filename in possible_files:         test_path = os.path.join(table_dir, filename)         if os.path.exists(test_path):             csv_path = test_path             break          if not csv_path:         print(f"❌ No CSV file found for {crime_type}")         return False          try:         # Load raw data         df = pd.read_csv(csv_path)         print(f"✅ Loaded {len(df)} records for {crime_type}")                  # Convert Date to datetime and extract time periods         df['Date'] = pd.to_datetime(df['Date'])                  # Add Time of Day (using hour from datetime, or create sample times)         df['Time of Day'] = df['Date'].dt.strftime('%H:%M') + '-' + (df['Date'].dt.hour + 4).astype(str).str.zfill(2) + ':59'                  # Map to time bins         def map_to_time_bin(time_str):             hour = int(time_str.split(':')[0])             if 0 <= hour <= 3:                 return "00:00-03:59"             elif 4 <= hour <= 7:                 return "04:00-07:59"             elif 8 <= hour <= 11:                 return "08:00-11:59"             elif 12 <= hour <= 15:                 return "12:00-15:59"             elif 16 <= hour <= 19:                 return "16:00-19:59"             else:                 return "20:00-23:59"                  df['Time of Day'] = df['Date'].dt.hour.apply(lambda h:              "00:00-03:59" if 0 <= h <= 3 else             "04:00-07:59" if 4 <= h <= 7 else             "08:00-11:59" if 8 <= h <= 11 else             "12:00-15:59" if 12 <= h <= 15 else             "16:00-19:59" if 16 <= h <= 19 else             "20:00-23:59"         )                  # Add Period based on date ranges         today = pd.to_datetime('2025-06-03')         df['Days_Ago'] = (today - df['Date']).dt.days                  # Create separate rows for each period a record falls into         processed_rows = []         for _, row in df.iterrows():             days_ago = row['Days_Ago']                          # Add to appropriate periods             if days_ago <= 7:                 new_row = row.copy()                 new_row['Period'] = '7-Day'                 processed_rows.append(new_row)                              if days_ago <= 28:                 new_row = row.copy()                 new_row['Period'] = '28-Day'                 processed_rows.append(new_row)                              # YTD (since Jan 1, 2025)             if row['Date'].year == 2025:                 new_row = row.copy()                 new_row['Period'] = 'YTD'                 processed_rows.append(new_row)                  # Create processed DataFrame         processed_df = pd.DataFrame(processed_rows)                  # Save processed data back to CSV         processed_df.to_csv(csv_path, index=False)         print(f"✅ Updated {csv_path} with Time of Day and Period columns")         print(f"  Periods: {processed_df['Period'].value_counts().to_dict()}")         print(f"  Time periods: {processed_df['Time of Day'].value_counts().to_dict()}")                  return True              except Exception as e:         print(f"❌ Error processing {crime_type}: {e}")         import traceback         traceback.print_exc()         return False  # Process all crime types print("🔄 Creating processed data for charts...") for crime_type in config.CRIME_TYPES:     success = create_processed_data_for_charts(crime_type)     if success:         print(f"✅ {crime_type} processed")     else:         print(f"❌ {crime_type} failed")

# Clear the map_export module from memory import sys if 'map_export' in sys.modules:     del sys.modules['map_export']     print("✅ Cleared map_export from memory")  # Add current directory to path and import import os current_dir = os.getcwd() if current_dir not in sys.path:     sys.path.insert(0, current_dir)  # Execute map_export directly to get the updated function with open("map_export.py", "r", encoding="utf-8") as f:     map_export_code = f.read()  map_export_namespace = {} exec(map_export_code, map_export_namespace)  print("✅ Loaded updated map_export functions")
# Test with the updated legend function test_args = ["main.py", "true", "false", "false", "30", "true", "2025_05_27"] test_crime = "MV Theft" test_output = r"C:\Users\carucci_r\OneDrive - City of Hackensack\_25_SCRPA\TIME_Based\Reports\TEST"  print(f"Testing UPDATED map export for: {test_crime}")  try:     # Use the updated export_maps function     result = map_export_namespace['export_maps'](test_crime, test_output, test_args)     print(f"🎯 Map export result: {result}")          if result:         print("✅ MAP EXPORT SUCCESSFUL!")                  # Check the file modification time to see if it's new         import glob         png_files = glob.glob(os.path.join(test_output, "MV_Theft_Map.png"))         if png_files:             latest_file = max(png_files, key=os.path.getmtime)             size = os.path.getsize(latest_file)             mod_time = os.path.getmtime(latest_file)             from datetime import datetime             print(f"📄 Latest: {os.path.basename(latest_file)}: {size:,} bytes")             print(f"📅 Modified: {datetime.fromtimestamp(mod_time)}")              else:         print("❌ Map export returned False")          except Exception as e:     print(f"❌ Error during map export: {e}")     import traceback     traceback.print_exc()
# Test all crime types to see if legends work for all print("🚀 TESTING ALL CRIME TYPES WITH UPDATED LEGEND FUNCTION")  crime_types = ["MV Theft", "Burglary - Auto", "Burglary - Comm & Res", "Robbery", "Sexual Offenses"]  success_count = 0 total_count = len(crime_types)  for crime_type in crime_types:     print(f"\n📊 Processing: {crime_type}")     try:         result = map_export_namespace['export_maps'](crime_type, test_output, test_args)         if result:             print(f"✅ {crime_type}: SUCCESS")             success_count += 1         else:             print(f"❌ {crime_type}: FAILED")     except Exception as e:         print(f"❌ {crime_type}: ERROR - {e}")  print(f"\n🎯 BATCH TEST COMPLETE!") print(f"✅ Successful: {success_count}/{total_count}")  # List all created files png_files = glob.glob(os.path.join(test_output, "*_Map.png")) print(f"\n📄 Created map files: {len(png_files)}") for file in png_files:     size = os.path.getsize(file)     mod_time = os.path.getmtime(file)     time_str = datetime.fromtimestamp(mod_time).strftime("%H:%M:%S")     print(f"  📄 {os.path.basename(file)}: {size:,} bytes ({time_str})")

.getsize(full_path)             print(f"✅ File created successfully: {full_path} ({file_size} bytes)")         else:             print(f"❌ File was not created: {full_path}")                  except Exception as export_error:         print(f"❌ Export error: {export_error}")                  # Try a simpler export         print("🔄 Trying simpler export...")         simple_path = os.path.join(crime_subfolder, "test_export.png")         try:             test_layout.exportToPNG(simple_path)             print(f"✅ Simple export worked: {simple_path}")         except Exception as simple_error:             print(f"❌ Simple export also failed: {simple_error}")          del aprx      except Exception as e:     print(f"❌ Debug error: {e}")     import traceback     traceback.print_exc()
